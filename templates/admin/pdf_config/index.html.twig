{% extends 'dashboard/layout.html.twig' %}
{% block title %}Configurations PDF Bailleurs{% endblock %}

{% block content %}
<style>
.badge-actif   { background:#e8f5e9; color:#2e7d32; padding:3px 10px; border-radius:12px; font-size:.78rem; font-weight:600; }
.badge-inactif { background:#ffebee; color:#c62828; padding:3px 10px; border-radius:12px; font-size:.78rem; font-weight:600; }
</style>

<div class="planning-container" style="max-width:1200px;margin:0 auto;padding:24px 16px;">

    <div class="page-header" style="background:linear-gradient(135deg,var(--primary) 0%,var(--primary-dark) 100%);color:white;padding:28px 24px;border-radius:12px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
        <h1 style="margin:0;font-size:1.8rem;font-weight:400;display:flex;align-items:center;gap:12px;">
            <i class="material-icons">picture_as_pdf</i> Configurations PDF Bailleurs
        </h1>
        <a href="{{ path('admin_pdf_config_new') }}" class="mdl-button mdl-js-button mdl-button--raised" style="background:white;color:var(--primary);">
            <i class="material-icons" style="vertical-align:middle;">add</i> Nouvelle config
        </a>
    </div>

    {% for label, msgs in app.flashes %}
        {% for msg in msgs %}
            <div class="mdl-shadow--2dp" style="padding:12px 16px;border-radius:8px;margin-bottom:16px;background:{{ label == 'success' ? '#e8f5e9' : '#ffebee' }};color:{{ label == 'success' ? '#2e7d32' : '#c62828' }};">
                <i class="material-icons" style="vertical-align:middle;font-size:18px;">{{ label == 'success' ? 'check_circle' : 'error' }}</i>
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if configs is empty %}
        <div style="text-align:center;padding:60px 20px;color:#9e9e9e;">
            <i class="material-icons" style="font-size:56px;display:block;margin-bottom:12px;">picture_as_pdf</i>
            <p style="font-size:1.1rem;">Aucune configuration. Créez-en une pour chaque bailleur.</p>
            <a href="{{ path('admin_pdf_config_new') }}" class="mdl-button mdl-js-button mdl-button--raised mdl-button--colored" style="margin-top:12px;">
                Créer la première config
            </a>
        </div>
    {% else %}
        <div class="mdl-shadow--2dp" style="background:var(--card-light);border-radius:12px;overflow:hidden;">
            <table class="mdl-data-table mdl-js-data-table" style="width:100%;table-layout:fixed;">
                <thead>
                    <tr>
                        <th class="mdl-data-table__cell--non-numeric" style="width:30%">Bailleur</th>
                        <th class="mdl-data-table__cell--non-numeric" style="width:30%">Texte identifiant</th>
                        <th style="width:10%">Priorité</th>
                        <th style="width:10%">Champs</th>
                        <th style="width:10%">Statut</th>
                        <th class="mdl-data-table__cell--non-numeric" style="width:10%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for config in configs %}
                    <tr>
                        <td class="mdl-data-table__cell--non-numeric"><strong>{{ config.nom }}</strong></td>
                        <td class="mdl-data-table__cell--non-numeric" style="font-family:monospace;font-size:.82rem;color:#666;">{{ config.identifiantTexte }}</td>
                        <td>{{ config.priorite }}</td>
                        <td>{{ config.fieldMappings|length }}</td>
                        <td>
                            {% if config.actif %}
                                <span class="badge-actif">Actif</span>
                            {% else %}
                                <span class="badge-inactif">Inactif</span>
                            {% endif %}
                        </td>
                        <td class="mdl-data-table__cell--non-numeric">
                            <a href="{{ path('admin_pdf_config_edit', {id: config.id}) }}" class="mdl-button mdl-js-button mdl-button--icon" title="Modifier">
                                <i class="material-icons">edit</i>
                            </a>
                            <form method="post" action="{{ path('admin_pdf_config_delete', {id: config.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette configuration ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ config.id) }}">
                                <button type="submit" class="mdl-button mdl-js-button mdl-button--icon" title="Supprimer" style="color:#e53935;">
                                    <i class="material-icons">delete</i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
