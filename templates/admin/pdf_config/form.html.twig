{% extends 'dashboard/layout.html.twig' %}
{% block title %}{{ isNew ? 'Nouvelle config PDF' : 'Modifier ' ~ config.nom }}{% endblock %}

{% block content %}
<style>
.form-card { background:var(--card-light); border-radius:12px; padding:24px; margin-bottom:20px; }
body.dark-mode .form-card { background:var(--card-dark); }
.field-label { font-size:.75rem; font-weight:700; color:#9e9e9e; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; }
.field-inp { width:100%; box-sizing:border-box; padding:10px 12px; border:2px solid var(--border-light); border-radius:8px; font-size:.95rem; background:var(--card-light); color:var(--text-light); }
body.dark-mode .field-inp { background:var(--card-dark); border-color:var(--border-dark); color:var(--text-dark); }
.field-inp:focus { outline:none; border-color:var(--primary); }

/* PDF preview */
.pdf-zone { border:2px dashed var(--border-light); border-radius:10px; padding:28px 20px; text-align:center; cursor:pointer; transition:.2s; }
body.dark-mode .pdf-zone { border-color:var(--border-dark); }
.pdf-zone:hover { border-color:var(--primary); background:rgba(63,81,181,.04); }
.pdf-lines { max-height:520px; overflow-y:auto; margin-top:14px; border:1px solid var(--border-light); border-radius:8px; }
body.dark-mode .pdf-lines { border-color:var(--border-dark); }

.pdf-line {
    display:flex; align-items:center; gap:8px;
    padding:7px 10px; border-bottom:1px solid var(--border-light);
    cursor:pointer; font-size:.84rem; font-family:monospace;
    transition:.12s; position:relative;
}
body.dark-mode .pdf-line { border-color:var(--border-dark); color:var(--text-dark); }
.pdf-line:hover { background:rgba(63,81,181,.07); }
.pdf-line.assigned { background:#e8f5e9; }
body.dark-mode .pdf-line.assigned { background:rgba(76,175,80,.14); }
.pdf-line.active-pick { background:rgba(63,81,181,.13); outline:2px solid var(--primary); outline-offset:-2px; }
.line-num { font-size:.7rem; color:#bbb; min-width:26px; text-align:right; flex-shrink:0; }
.line-chip {
    font-size:.68rem; padding:2px 8px; border-radius:10px;
    background:var(--primary); color:white; font-weight:600;
    margin-left:auto; flex-shrink:0; white-space:nowrap;
    display:flex; align-items:center; gap:4px;
}
.line-chip .chip-del { cursor:pointer; opacity:.7; font-size:12px; line-height:1; }
.line-chip .chip-del:hover { opacity:1; }

/* Inline field picker dropdown */
#fieldPicker {
    display:none;
    position:fixed;
    z-index:9999;
    background:var(--card-light);
    border:1.5px solid var(--primary);
    border-radius:10px;
    box-shadow:0 6px 24px rgba(0,0,0,.18);
    min-width:220px;
    overflow:hidden;
}
body.dark-mode #fieldPicker { background:var(--card-dark); }
#fieldPicker.open { display:block; }
.picker-header {
    padding:8px 12px 6px;
    font-size:.72rem; font-weight:700; color:var(--primary);
    text-transform:uppercase; letter-spacing:.5px;
    border-bottom:1px solid var(--border-light);
}
body.dark-mode .picker-header { border-color:var(--border-dark); }
.picker-item {
    display:flex; align-items:center; gap:10px;
    padding:9px 14px; cursor:pointer; font-size:.88rem;
    transition:.1s;
}
.picker-item:hover { background:rgba(63,81,181,.08); }
.picker-item .picker-icon { font-size:16px; color:var(--primary); flex-shrink:0; }
.picker-item .picker-label { font-weight:500; }
.picker-item .picker-check { margin-left:auto; color:#4caf50; font-size:16px; display:none; }
.picker-item.already-set .picker-check { display:block; }
.picker-sep { height:1px; background:var(--border-light); margin:4px 0; }
body.dark-mode .picker-sep { background:var(--border-dark); }
.picker-cancel { padding:8px 14px 10px; font-size:.8rem; color:#e53935; cursor:pointer; text-align:center; }
.picker-cancel:hover { background:rgba(229,57,53,.07); }

/* Mappings summary */
.mapping-row { display:flex; align-items:center; gap:10px; background:rgba(63,81,181,.04); border-radius:8px; padding:10px 14px; margin-bottom:8px; border:1px solid rgba(63,81,181,.12); }
body.dark-mode .mapping-row { background:rgba(63,81,181,.08); }
.del-btn { background:none; border:none; cursor:pointer; color:#e53935; padding:4px; border-radius:4px; display:flex; align-items:center; margin-left:auto; flex-shrink:0; }
.del-btn:hover { background:rgba(229,57,53,.1); }

@keyframes spin { to { transform:rotate(360deg); } }
</style>

<div style="max-width:1300px;margin:0 auto;padding:24px 16px;">

    <div class="page-header" style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:white;padding:24px;border-radius:12px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
        <h1 style="margin:0;font-size:1.6rem;font-weight:400;display:flex;align-items:center;gap:10px;">
            <i class="material-icons">picture_as_pdf</i>
            {{ isNew ? 'Nouvelle configuration PDF' : 'Modifier : ' ~ config.nom }}
        </h1>
        <a href="{{ path('admin_pdf_config_index') }}" class="mdl-button mdl-js-button" style="color:rgba(255,255,255,.85);">
            <i class="material-icons" style="vertical-align:middle;">arrow_back</i> Retour
        </a>
    </div>

    {% for label, msgs in app.flashes %}
        {% for msg in msgs %}
            <div style="padding:12px 16px;border-radius:8px;margin-bottom:16px;background:{{ label=='success'?'#e8f5e9':'#ffebee' }};color:{{ label=='success'?'#2e7d32':'#c62828' }};">{{ msg }}</div>
        {% endfor %}
    {% endfor %}

    <form method="post" id="mainForm">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

            <!-- LEFT: PDF preview -->
            <div>
                <div class="form-card">
                    <h3 style="margin:0 0 16px;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;">
                        <i class="material-icons" style="color:var(--primary);">upload_file</i> PDF exemple
                    </h3>

                    <div class="pdf-zone" id="pdfZone" onclick="document.getElementById('pdfFile').click()">
                        <i class="material-icons" style="font-size:42px;color:#9e9e9e;">picture_as_pdf</i>
                        <p style="margin:8px 0 0;color:#9e9e9e;font-size:.9rem;">Cliquez pour charger un PDF exemple</p>
                        <p style="margin:4px 0 0;color:#bbb;font-size:.78rem;">Chaque ligne sera cliquable pour assigner un champ</p>
                    </div>
                    <input type="file" id="pdfFile" accept=".pdf" style="display:none;" onchange="loadPdf(this)">

                    <div id="pdfLoading" style="display:none;text-align:center;padding:20px;color:#9e9e9e;">
                        <i class="material-icons" style="font-size:32px;animation:spin 1s linear infinite;">refresh</i>
                        <p style="margin:8px 0 0;">Extraction en cours…</p>
                    </div>

                    <div id="pdfLinesContainer" style="display:none;">
                        <p style="margin:12px 0 6px;font-size:.8rem;color:#9e9e9e;">
                            <i class="material-icons" style="font-size:14px;vertical-align:middle;">touch_app</i>
                            Cliquez sur une ligne pour choisir le champ à lui assigner
                        </p>
                        <div class="pdf-lines" id="pdfLines"></div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Config + mappings -->
            <div>
                <div class="form-card">
                    <h3 style="margin:0 0 16px;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;">
                        <i class="material-icons" style="color:var(--primary);">settings</i> Informations
                    </h3>
                    <div style="display:grid;gap:14px;">
                        <div>
                            <div class="field-label">Nom du bailleur *</div>
                            <input class="field-inp" type="text" name="nom" value="{{ config.nom }}" placeholder="Ex: Paris Habitat" required>
                        </div>
                        <div>
                            <div class="field-label">Texte identifiant *</div>
                            <input class="field-inp" type="text" name="identifiantTexte" value="{{ config.identifiantTexte }}" placeholder="Texte unique présent dans tous les PDFs de ce bailleur">
                            <p style="font-size:.75rem;color:#9e9e9e;margin:4px 0 0;">Ce texte sert à reconnaître automatiquement les PDFs de ce bailleur.</p>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                            <div>
                                <div class="field-label">Priorité</div>
                                <input class="field-inp" type="number" name="priorite" value="{{ config.priorite }}" min="1" max="999">
                            </div>
                            <div style="display:flex;align-items:center;gap:10px;padding-top:18px;">
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                                    <input type="checkbox" name="actif" value="1" {{ config.actif ? 'checked' : '' }} style="accent-color:var(--primary);width:18px;height:18px;">
                                    <span style="font-weight:500;">Config active</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-card">
                    <h3 style="margin:0 0 14px;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;">
                        <i class="material-icons" style="color:var(--primary);">tune</i> Champs mappés
                        <span id="mappingCount" style="margin-left:auto;background:rgba(63,81,181,.1);color:var(--primary);font-size:.75rem;font-weight:700;padding:2px 8px;border-radius:10px;">0</span>
                    </h3>

                    <div id="mappingRows">
                        <p id="emptyMappings" style="color:#9e9e9e;font-size:.85rem;text-align:center;padding:16px 0;">
                            <i class="material-icons" style="font-size:20px;vertical-align:middle;display:block;margin-bottom:6px;">touch_app</i>
                            Chargez un PDF et cliquez sur les lignes pour assigner les champs
                        </p>
                    </div>

                    <input type="hidden" name="fieldMappings" id="fieldMappingsInput">
                </div>

                <div style="text-align:right;">
                    <button type="submit" class="mdl-button mdl-js-button mdl-button--raised mdl-button--colored" style="padding:0 28px;height:44px;font-size:1rem;">
                        <i class="material-icons" style="vertical-align:middle;">save</i>
                        {{ isNew ? 'Créer la configuration' : 'Enregistrer' }}
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Floating field picker -->
<div id="fieldPicker">
    <div class="picker-header">Assigner à quel champ ?</div>
    <div id="pickerItems"></div>
    <div class="picker-sep"></div>
    <div class="picker-cancel" onclick="closePicker()">Annuler</div>
</div>

<script>
const DB_FIELDS = [
    { key:'numeroCommande',          label:'N° de commande',           icon:'tag',            strategy:'line_index' },
    { key:'clientNom',               label:'Nom du client / occupant', icon:'person',         strategy:'line_index' },
    { key:'clientAdresse',           label:'Adresse',                  icon:'home',           strategy:'line_index' },
    { key:'clientComplementAdresse', label:'Complément d\'adresse',    icon:'apartment',      strategy:'line_index' },
    { key:'clientTelephone',         label:'Téléphone',                icon:'phone',          strategy:'line_index' },
    { key:'dateLimiteExecution',     label:'Date limite d\'exécution', icon:'event',          strategy:'line_index_date' },
    { key:'typePrestation',          label:'Type de prestation',       icon:'build',          strategy:'type_prestation_code' },
];
const DB_FIELDS_MAP = Object.fromEntries(DB_FIELDS.map(f => [f.key, f]));

let mappings = {{ config.fieldMappings|json_encode|raw }};
let pickerLineIndex = -1;
let pickerLineEl    = null;

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    renderAllMappings();
    syncHiddenInput();
});

// ── PDF loading ───────────────────────────────────────────────────────────────
async function loadPdf(input) {
    const file = input.files[0];
    if (!file) return;
    document.getElementById('pdfLoading').style.display = 'block';
    document.getElementById('pdfLinesContainer').style.display = 'none';
    document.getElementById('pdfZone').style.display = 'none';

    const fd = new FormData();
    fd.append('pdf', file);
    const res  = await fetch('{{ path('admin_pdf_config_preview') }}', { method:'POST', body:fd });
    const data = await res.json();
    document.getElementById('pdfLoading').style.display = 'none';

    if (!data.success) { alert('Erreur lors de l\'extraction du PDF.'); return; }

    const container = document.getElementById('pdfLines');
    container.innerHTML = data.lines.map(l => `
        <div class="pdf-line" data-index="${l.index}" onclick="onLineClick(event, ${l.index}, this)">
            <span class="line-num">${l.index}</span>
            <span class="line-text" style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(l.text)}</span>
        </div>
    `).join('');
    document.getElementById('pdfLinesContainer').style.display = 'block';
    refreshLineHighlights();
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Field picker ──────────────────────────────────────────────────────────────
function onLineClick(evt, lineIndex, lineEl) {
    evt.stopPropagation();

    // Toggle: if picker already open for this line, close it
    if (pickerLineIndex === lineIndex && document.getElementById('fieldPicker').classList.contains('open')) {
        closePicker();
        return;
    }

    pickerLineIndex = lineIndex;
    pickerLineEl    = lineEl;

    // Mark active
    document.querySelectorAll('.pdf-line').forEach(el => el.classList.remove('active-pick'));
    lineEl.classList.add('active-pick');

    // Build picker items
    const assignedKeys = new Set(mappings.map(m => m.dbField));
    const items = DB_FIELDS.map(f => {
        const isSet = assignedKeys.has(f.key) && mappings.find(m => m.dbField === f.key)?.lineIndex === lineIndex;
        return `
            <div class="picker-item ${isSet ? 'already-set' : ''}" onclick="assignField('${f.key}')">
                <i class="material-icons picker-icon">${f.icon}</i>
                <span class="picker-label">${f.label}</span>
                <i class="material-icons picker-check">check_circle</i>
            </div>`;
    }).join('');
    document.getElementById('pickerItems').innerHTML = items;

    // Position picker near the clicked line
    const picker = document.getElementById('fieldPicker');
    picker.classList.add('open');

    const rect = lineEl.getBoundingClientRect();
    const pw   = picker.offsetWidth  || 230;
    const ph   = picker.offsetHeight || 320;
    let top  = rect.bottom + 4;
    let left = rect.left;

    if (top + ph > window.innerHeight - 8)  top  = rect.top - ph - 4;
    if (left + pw > window.innerWidth  - 8) left = window.innerWidth - pw - 8;
    picker.style.top  = top  + 'px';
    picker.style.left = left + 'px';
}

function assignField(fieldKey) {
    const fieldDef = DB_FIELDS_MAP[fieldKey];
    const mapping = {
        dbField:    fieldKey,
        strategy:   fieldDef.strategy,
        lineIndex:  pickerLineIndex,
    };

    // Replace existing mapping for same field
    mappings = mappings.filter(m => m.dbField !== fieldKey);
    mappings.push(mapping);

    renderAllMappings();
    syncHiddenInput();
    refreshLineHighlights();
    closePicker();
}

function closePicker() {
    document.getElementById('fieldPicker').classList.remove('open');
    document.querySelectorAll('.pdf-line').forEach(el => el.classList.remove('active-pick'));
    pickerLineIndex = -1;
    pickerLineEl    = null;
}

// Close picker when clicking outside
document.addEventListener('click', e => {
    const picker = document.getElementById('fieldPicker');
    if (picker.classList.contains('open') && !picker.contains(e.target) && !e.target.closest('.pdf-line')) {
        closePicker();
    }
});

// ── Mappings summary ──────────────────────────────────────────────────────────
function renderAllMappings() {
    const container = document.getElementById('mappingRows');
    const empty     = document.getElementById('emptyMappings');

    if (!mappings.length) {
        container.innerHTML = '';
        container.appendChild(empty);
        document.getElementById('mappingCount').textContent = '0';
        return;
    }

    // Sort by lineIndex
    const sorted = [...mappings].sort((a, b) => (a.lineIndex ?? 999) - (b.lineIndex ?? 999));

    container.innerHTML = sorted.map(m => {
        const f = DB_FIELDS_MAP[m.dbField];
        const lineInfo = m.strategy === 'type_prestation_code' ? 'Auto-détection' : `Ligne ${m.lineIndex}`;
        return `
        <div class="mapping-row" data-field="${m.dbField}">
            <i class="material-icons" style="color:var(--primary);flex-shrink:0;">${f?.icon ?? 'label'}</i>
            <div style="flex:1;min-width:0;">
                <div style="font-weight:600;font-size:.88rem;">${f?.label ?? m.dbField}</div>
                <div style="font-size:.75rem;color:#9e9e9e;">${lineInfo}</div>
            </div>
            <button type="button" class="del-btn" onclick="removeMapping('${m.dbField}')">
                <i class="material-icons">close</i>
            </button>
        </div>`;
    }).join('');

    document.getElementById('mappingCount').textContent = mappings.length;
}

function removeMapping(field) {
    mappings = mappings.filter(m => m.dbField !== field);
    renderAllMappings();
    syncHiddenInput();
    refreshLineHighlights();
}

function syncHiddenInput() {
    document.getElementById('fieldMappingsInput').value = JSON.stringify(mappings);
}

// ── Line highlights ───────────────────────────────────────────────────────────
function refreshLineHighlights() {
    const fieldByLine = {};
    mappings.forEach(m => { if (m.lineIndex != null) fieldByLine[m.lineIndex] = m.dbField; });

    document.querySelectorAll('.pdf-line').forEach(el => {
        const idx = parseInt(el.dataset.index);
        const field = fieldByLine[idx];

        // Remove existing chip
        el.querySelector('.line-chip')?.remove();
        el.classList.remove('assigned');

        if (field) {
            el.classList.add('assigned');
            const f = DB_FIELDS_MAP[field];
            const chip = document.createElement('span');
            chip.className = 'line-chip';
            chip.innerHTML = `${f?.label ?? field} <span class="chip-del" onclick="event.stopPropagation();removeMapping('${field}')">✕</span>`;
            el.appendChild(chip);
        }
    });
}
</script>
{% endblock %}
