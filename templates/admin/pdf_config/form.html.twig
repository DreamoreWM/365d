{% extends 'dashboard/layout.html.twig' %}
{% block title %}{{ isNew ? 'Nouvelle config PDF' : 'Modifier ' ~ config.nom }}{% endblock %}

{% block content %}
<style>
.form-card { background:var(--card-light); border-radius:12px; padding:24px; margin-bottom:20px; }
body.dark-mode .form-card { background:var(--card-dark); }
.field-label { font-size:.75rem; font-weight:700; color:#9e9e9e; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; }
.field-inp { width:100%; box-sizing:border-box; padding:10px 12px; border:2px solid var(--border-light); border-radius:8px; font-size:.95rem; background:var(--card-light); color:var(--text-light); }
body.dark-mode .field-inp { background:var(--card-dark); border-color:var(--border-dark); color:var(--text-dark); }
.field-inp:focus { outline:none; border-color:var(--primary); }

/* PDF viewer */
.pdf-drop-zone {
    border:2px dashed var(--border-light); border-radius:10px;
    padding:36px 20px; text-align:center; cursor:pointer; transition:.2s;
}
body.dark-mode .pdf-drop-zone { border-color:var(--border-dark); }
.pdf-drop-zone:hover { border-color:var(--primary); background:rgba(63,81,181,.04); }

#pdfViewer {
    background:#e0e0e0;
    border-radius:8px;
    overflow-y:auto;
    max-height:680px;
    padding:16px 0;
    display:none;
    user-select:text; /* allow text selection */
}
body.dark-mode #pdfViewer { background:#2a2a2a; }

.pdf-page-wrap {
    position:relative;
    display:block;
    margin:0 auto 16px;
    box-shadow:0 4px 16px rgba(0,0,0,.25);
    line-height:0;
}
.pdf-page-wrap canvas { display:block; }

/* Text layer */
.textLayer {
    position:absolute;
    inset:0;
    overflow:hidden;
    pointer-events:none;
    line-height:1;
}
.textLayer span {
    color:transparent;
    position:absolute;
    white-space:pre;
    cursor:text;           /* text cursor → signals selectable */
    pointer-events:all;
    border-radius:2px;
    transform-origin:0% 0%;
    transition:background .1s;
}
/* Visible text selection highlight */
.textLayer span::selection {
    background:rgba(63,81,181,.35);
    color:transparent;
}
.textLayer span:hover               { background:rgba(63,81,181,.14); }
.textLayer span.tl-assigned         { background:rgba(76,175,80,.30)  !important; }
.textLayer span.tl-assigned-partial { background:rgba(255,152,0,.35)  !important; }
.textLayer span.tl-active           { background:rgba(63,81,181,.30)  !important; }

/* Field picker */
#fieldPicker {
    display:none; position:fixed; z-index:9999;
    background:var(--card-light);
    border:1.5px solid var(--primary);
    border-radius:10px;
    box-shadow:0 6px 28px rgba(0,0,0,.22);
    min-width:240px; overflow:hidden;
}
body.dark-mode #fieldPicker { background:var(--card-dark); }
#fieldPicker.open { display:block; }

.picker-header {
    padding:9px 14px 7px; font-size:.7rem; font-weight:700;
    color:var(--primary); text-transform:uppercase; letter-spacing:.5px;
    border-bottom:1px solid var(--border-light); background:rgba(63,81,181,.05);
}
body.dark-mode .picker-header { border-color:var(--border-dark); }

/* Selection badge shown in picker */
.picker-sel-badge {
    display:flex; align-items:center; gap:6px;
    padding:6px 12px; font-size:.76rem;
    border-bottom:1px solid var(--border-light);
    background:rgba(63,81,181,.06);
}
body.dark-mode .picker-sel-badge { border-color:var(--border-dark); background:rgba(63,81,181,.12); }
.picker-sel-badge .sel-label { font-weight:700; color:var(--primary); flex-shrink:0; font-size:.68rem; text-transform:uppercase; }
.picker-sel-badge .sel-text  { font-family:monospace; color:var(--text-light); background:rgba(0,0,0,.06); border-radius:4px; padding:2px 6px; max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
body.dark-mode .picker-sel-badge .sel-text { color:var(--text-dark); background:rgba(255,255,255,.08); }

.picker-item {
    display:flex; align-items:center; gap:10px;
    padding:9px 14px; cursor:pointer; font-size:.88rem; transition:.1s;
}
.picker-item:hover { background:rgba(63,81,181,.09); }
.picker-item .pi-icon  { font-size:17px; color:var(--primary); flex-shrink:0; }
.picker-item .pi-label { font-weight:500; flex:1; }
.picker-item .pi-check { margin-left:auto; color:#4caf50; font-size:16px; display:none; }
.picker-item.is-set .pi-check { display:block; }
.picker-sep { height:1px; background:var(--border-light); }
body.dark-mode .picker-sep { background:var(--border-dark); }
.picker-cancel { padding:8px 14px 10px; font-size:.8rem; color:#e53935; cursor:pointer; text-align:center; }
.picker-cancel:hover { background:rgba(229,57,53,.07); }

/* Mapping rows */
.mapping-row { display:flex; align-items:center; gap:10px; background:rgba(63,81,181,.04); border-radius:8px; padding:10px 14px; margin-bottom:8px; border:1px solid rgba(63,81,181,.12); }
body.dark-mode .mapping-row { background:rgba(63,81,181,.08); }
.mapping-row.partial { border-color:rgba(255,152,0,.35); background:rgba(255,152,0,.05); }
.del-btn { background:none; border:none; cursor:pointer; color:#e53935; padding:4px; border-radius:4px; display:flex; align-items:center; margin-left:auto; flex-shrink:0; }
.del-btn:hover { background:rgba(229,57,53,.1); }

@keyframes spin { to { transform:rotate(360deg); } }
</style>

<div style="max-width:1400px;margin:0 auto;padding:24px 16px;">

    <div class="page-header" style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:white;padding:24px;border-radius:12px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
        <h1 style="margin:0;font-size:1.6rem;font-weight:400;display:flex;align-items:center;gap:10px;">
            <i class="material-icons">picture_as_pdf</i>
            {{ isNew ? 'Nouvelle configuration PDF' : 'Modifier : ' ~ config.nom }}
        </h1>
        <a href="{{ path('admin_pdf_config_index') }}" class="mdl-button mdl-js-button" style="color:rgba(255,255,255,.85);">
            <i class="material-icons" style="vertical-align:middle;">arrow_back</i> Retour
        </a>
    </div>

    {% for label, msgs in app.flashes %}
        {% for msg in msgs %}
            <div style="padding:12px 16px;border-radius:8px;margin-bottom:16px;background:{{ label=='success'?'#e8f5e9':'#ffebee' }};color:{{ label=='success'?'#2e7d32':'#c62828' }};">{{ msg }}</div>
        {% endfor %}
    {% endfor %}

    <form method="post" id="mainForm">
        <div style="display:grid;grid-template-columns:1.1fr .9fr;gap:20px;align-items:start;">

            <!-- LEFT: PDF visual viewer -->
            <div>
                <div class="form-card" style="padding:20px;">
                    <h3 style="margin:0 0 14px;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;">
                        <i class="material-icons" style="color:var(--primary);">picture_as_pdf</i> PDF exemple
                        <span id="pdfPageInfo" style="margin-left:auto;font-size:.78rem;color:#9e9e9e;font-weight:400;"></span>
                    </h3>

                    <div class="pdf-drop-zone" id="pdfDropZone" onclick="document.getElementById('pdfFile').click()">
                        <i class="material-icons" style="font-size:48px;color:#bbb;">upload_file</i>
                        <p style="margin:10px 0 4px;color:#9e9e9e;font-size:.95rem;">Cliquez ou déposez un PDF ici</p>
                        <p style="margin:0;color:#bbb;font-size:.78rem;">Le PDF s'affiche tel quel — cliquez ou sélectionnez du texte pour assigner les champs</p>
                    </div>
                    <input type="file" id="pdfFile" accept=".pdf" style="display:none;" onchange="loadPdf(this.files[0])">

                    <div id="pdfLoading" style="display:none;text-align:center;padding:32px;color:#9e9e9e;">
                        <i class="material-icons" style="font-size:36px;animation:spin 1s linear infinite;display:block;">refresh</i>
                        <p style="margin:10px 0 0;">Rendu en cours…</p>
                    </div>

                    <div id="pdfViewer"></div>

                    <p id="pdfHint" style="display:none;margin:10px 0 0;font-size:.78rem;color:#9e9e9e;">
                        <i class="material-icons" style="font-size:14px;vertical-align:middle;">touch_app</i>
                        <strong>Clic</strong> = toute la ligne &nbsp;·&nbsp;
                        <i class="material-icons" style="font-size:14px;vertical-align:middle;">text_fields</i>
                        <strong>Sélection</strong> = portion du texte
                    </p>
                </div>
            </div>

            <!-- RIGHT: Config + mappings -->
            <div style="position:sticky;top:16px;">
                <div class="form-card">
                    <h3 style="margin:0 0 16px;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;">
                        <i class="material-icons" style="color:var(--primary);">settings</i> Informations
                    </h3>
                    <div style="display:grid;gap:14px;">
                        <div>
                            <div class="field-label">Nom du bailleur *</div>
                            <input class="field-inp" type="text" name="nom" value="{{ config.nom }}" placeholder="Ex: Paris Habitat" required>
                        </div>
                        <div>
                            <div class="field-label">Texte identifiant *</div>
                            <input class="field-inp" type="text" name="identifiantTexte" value="{{ config.identifiantTexte }}" placeholder="Texte unique présent dans tous les PDFs">
                            <p style="font-size:.75rem;color:#9e9e9e;margin:4px 0 0;">Ce texte sert à reconnaître automatiquement les PDFs de ce bailleur.</p>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                            <div>
                                <div class="field-label">Priorité</div>
                                <input class="field-inp" type="number" name="priorite" value="{{ config.priorite }}" min="1" max="999">
                            </div>
                            <div style="display:flex;align-items:center;padding-top:20px;">
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                                    <input type="checkbox" name="actif" value="1" {{ config.actif ? 'checked' : '' }} style="accent-color:var(--primary);width:18px;height:18px;">
                                    <span style="font-weight:500;">Config active</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-card">
                    <h3 style="margin:0 0 14px;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;">
                        <i class="material-icons" style="color:var(--primary);">tune</i> Champs mappés
                        <span id="mappingCount" style="margin-left:auto;background:rgba(63,81,181,.1);color:var(--primary);font-size:.75rem;font-weight:700;padding:2px 8px;border-radius:10px;">0</span>
                    </h3>
                    <div id="mappingRows">
                        <p id="emptyMappings" style="color:#9e9e9e;font-size:.84rem;text-align:center;padding:14px 0;">
                            <i class="material-icons" style="font-size:22px;vertical-align:middle;display:block;margin-bottom:6px;">touch_app</i>
                            Cliquez ou sélectionnez du texte dans le PDF
                        </p>
                    </div>
                    <input type="hidden" name="fieldMappings" id="fieldMappingsInput">
                </div>

                <div style="text-align:right;">
                    <button type="submit" class="mdl-button mdl-js-button mdl-button--raised mdl-button--colored" style="padding:0 28px;height:44px;font-size:1rem;">
                        <i class="material-icons" style="vertical-align:middle;">save</i>
                        {{ isNew ? 'Créer la configuration' : 'Enregistrer' }}
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>

<!-- Floating field picker -->
<div id="fieldPicker">
    <div class="picker-header" id="pickerHeader">Assigner à quel champ ?</div>
    <div class="picker-sel-badge" id="pickerSelBadge" style="display:none;">
        <span class="sel-label">Extrait</span>
        <span class="sel-text" id="pickerSelText"></span>
    </div>
    <div id="pickerItems"></div>
    <div class="picker-sep"></div>
    <div class="picker-cancel" onclick="closePicker()">Annuler</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

const DB_FIELDS = [
    { key:'numeroCommande',          label:'N° de commande',          icon:'tag',       strategy:'line_index' },
    { key:'clientNom',               label:'Nom client / occupant',   icon:'person',    strategy:'line_index' },
    { key:'clientAdresse',           label:'Adresse',                 icon:'home',      strategy:'line_index' },
    { key:'clientComplementAdresse', label:'Complément d\'adresse',   icon:'apartment', strategy:'line_index' },
    { key:'clientTelephone',         label:'Téléphone',               icon:'phone',     strategy:'line_index' },
    { key:'dateLimiteExecution',     label:'Date limite d\'exécution',icon:'event',     strategy:'line_index_date' },
    { key:'typePrestation',          label:'Type de prestation',      icon:'build',     strategy:'type_prestation_code' },
];
const FIELDS_MAP = Object.fromEntries(DB_FIELDS.map(f => [f.key, f]));

let mappings    = {{ config.fieldMappings|json_encode|raw }};
let serverLines = [];

// picker state
let pickerLineIndex  = -1;
let pickerSelection  = null; // null = whole line, else the selected text string
let activeSpan       = null;

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    renderAllMappings();
    syncHidden();
});

// ── Load PDF ──────────────────────────────────────────────────────────────────
async function loadPdf(file) {
    if (!file) return;
    document.getElementById('pdfDropZone').style.display = 'none';
    document.getElementById('pdfLoading').style.display  = 'block';
    document.getElementById('pdfViewer').style.display   = 'none';
    document.getElementById('pdfHint').style.display     = 'none';

    const fd = new FormData();
    fd.append('pdf', file);
    const serverPromise = fetch('{{ path('admin_pdf_config_preview') }}', { method:'POST', body:fd }).then(r => r.json());

    const arrayBuffer = await file.arrayBuffer();
    const pdfDoc = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;

    const serverData = await serverPromise;
    if (serverData.success) serverLines = serverData.lines.map(l => l.text);

    const viewer = document.getElementById('pdfViewer');
    viewer.innerHTML = '';
    const totalPages = pdfDoc.numPages;
    document.getElementById('pdfPageInfo').textContent = totalPages + ' page' + (totalPages > 1 ? 's' : '');

    const SCALE = 1.4;
    for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
        const page     = await pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale: SCALE });

        const wrap = document.createElement('div');
        wrap.className = 'pdf-page-wrap';
        wrap.style.width  = viewport.width  + 'px';
        wrap.style.height = viewport.height + 'px';

        const canvas = document.createElement('canvas');
        canvas.width  = viewport.width;
        canvas.height = viewport.height;
        await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
        wrap.appendChild(canvas);

        const textLayerDiv = document.createElement('div');
        textLayerDiv.className = 'textLayer';
        textLayerDiv.style.width  = viewport.width  + 'px';
        textLayerDiv.style.height = viewport.height + 'px';

        const textContent = await page.getTextContent();
        const textDivs    = [];
        await pdfjsLib.renderTextLayer({ textContentSource: textContent, container: textLayerDiv, viewport, textDivs }).promise;

        textDivs.forEach(div => {
            const raw = div.textContent?.trim();
            if (!raw) return;
            const idx = findLineIndex(raw);
            if (idx < 0) return;
            div.dataset.lineIndex = idx;
        });

        wrap.appendChild(textLayerDiv);
        viewer.appendChild(wrap);
    }

    // Single mouseup handler on the whole viewer
    viewer.addEventListener('mouseup', onViewerMouseUp);

    document.getElementById('pdfLoading').style.display = 'none';
    document.getElementById('pdfViewer').style.display  = 'block';
    document.getElementById('pdfHint').style.display    = 'block';

    refreshSpanHighlights();
}

function findLineIndex(text) {
    const needle = text.trim().toLowerCase();
    if (needle.length < 2) return -1;
    let idx = serverLines.findIndex(l => l.toLowerCase().includes(needle));
    if (idx >= 0) return idx;
    idx = serverLines.findIndex(l => {
        const hay = l.trim().toLowerCase();
        return hay.length >= 4 && needle.includes(hay.substring(0, Math.min(hay.length, 20)));
    });
    return idx;
}

// ── Mouse up — handles both click and selection ───────────────────────────────
function onViewerMouseUp(e) {
    const sel     = window.getSelection();
    const selText = sel?.toString().trim();

    if (selText && selText.length >= 2) {
        // ── User made a text SELECTION ──────────────────────────────────────
        const anchorSpan = sel.anchorNode?.parentElement?.closest('[data-line-index]');
        if (!anchorSpan) { sel.removeAllRanges(); return; }
        const lineIdx = parseInt(anchorSpan.dataset.lineIndex);
        sel.removeAllRanges();
        openPicker(e, lineIdx, selText);

    } else {
        // ── Simple click on a span (whole line) ─────────────────────────────
        const span = e.target.closest('[data-line-index]');
        if (!span) return;
        const lineIdx = parseInt(span.dataset.lineIndex);
        if (activeSpan) activeSpan.classList.remove('tl-active');
        activeSpan = span;
        span.classList.add('tl-active');
        openPicker(e, lineIdx, null);
    }
}

// ── Field picker ──────────────────────────────────────────────────────────────
function openPicker(e, lineIndex, selectionText) {
    pickerLineIndex = lineIndex;
    pickerSelection = selectionText; // null = whole line

    // Header & selection badge
    if (selectionText) {
        document.getElementById('pickerHeader').textContent  = 'Assigner la sélection à :';
        document.getElementById('pickerSelBadge').style.display = 'flex';
        document.getElementById('pickerSelText').textContent = selectionText;
    } else {
        document.getElementById('pickerHeader').textContent  = 'Assigner la ligne à :';
        document.getElementById('pickerSelBadge').style.display = 'none';
    }

    // Items — mark already-set fields
    const assignedByLine = {};
    mappings.forEach(m => { if (m.lineIndex != null) assignedByLine[m.lineIndex + '_' + m.dbField] = true; });

    document.getElementById('pickerItems').innerHTML = DB_FIELDS.map(f => {
        const isSet = assignedByLine[lineIndex + '_' + f.key] ?? false;
        return `<div class="picker-item ${isSet ? 'is-set' : ''}" onclick="assignField('${f.key}')">
            <i class="material-icons pi-icon">${f.icon}</i>
            <span class="pi-label">${f.label}</span>
            <i class="material-icons pi-check">check_circle</i>
        </div>`;
    }).join('');

    // Position
    const picker = document.getElementById('fieldPicker');
    picker.classList.add('open');
    const pw = 260, ph = picker.offsetHeight || 360;
    let top  = e.clientY + 8;
    let left = e.clientX;
    if (top  + ph > window.innerHeight - 8) top  = e.clientY - ph - 8;
    if (left + pw > window.innerWidth  - 8) left = window.innerWidth  - pw - 8;
    if (left < 8) left = 8;
    picker.style.top  = top  + 'px';
    picker.style.left = left + 'px';
}

function assignField(fieldKey) {
    const f = FIELDS_MAP[fieldKey];
    const isPartial = pickerSelection !== null && fieldKey !== 'typePrestation';

    let strategy, mapping;
    if (fieldKey === 'typePrestation') {
        strategy = 'type_prestation_code';
        mapping  = { dbField: fieldKey, strategy, lineIndex: pickerLineIndex };
    } else if (isPartial) {
        // Selection: use regex to extract only the chosen portion
        strategy = f.key === 'dateLimiteExecution' ? 'line_index_date' : 'line_index_regex';
        const escaped = pickerSelection.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        mapping = {
            dbField:    fieldKey,
            strategy,
            lineIndex:  pickerLineIndex,
            regex:      '/(' + escaped + ')/',
            regexGroup: 1,
            _preview:   pickerSelection,
        };
    } else {
        strategy = f.strategy;
        mapping  = { dbField: fieldKey, strategy, lineIndex: pickerLineIndex };
    }

    mappings = mappings.filter(m => m.dbField !== fieldKey);
    mappings.push(mapping);

    renderAllMappings();
    syncHidden();
    refreshSpanHighlights();
    closePicker();
}

function closePicker() {
    document.getElementById('fieldPicker').classList.remove('open');
    if (activeSpan) { activeSpan.classList.remove('tl-active'); activeSpan = null; }
    pickerLineIndex = -1;
    pickerSelection = null;
}

document.addEventListener('click', e => {
    const picker = document.getElementById('fieldPicker');
    if (picker.classList.contains('open') && !picker.contains(e.target) && !e.target.closest('#pdfViewer')) {
        closePicker();
    }
});

// ── Mappings panel ────────────────────────────────────────────────────────────
function renderAllMappings() {
    const container = document.getElementById('mappingRows');
    const empty     = document.getElementById('emptyMappings');
    if (!mappings.length) {
        container.innerHTML = '';
        container.appendChild(empty);
        document.getElementById('mappingCount').textContent = '0';
        return;
    }
    const sorted = [...mappings].sort((a, b) => (a.lineIndex ?? 999) - (b.lineIndex ?? 999));
    container.innerHTML = sorted.map(m => {
        const f        = FIELDS_MAP[m.dbField];
        const isPartial = !!m._preview || (m.strategy === 'line_index_regex' && m.regex);
        const lineInfo = m.strategy === 'type_prestation_code'
            ? 'Auto-détection'
            : 'Ligne ' + m.lineIndex + (isPartial ? ` · <span style="font-family:monospace;color:#e65100;">"${m._preview ?? ''}"</span>` : '');
        return `<div class="mapping-row ${isPartial ? 'partial' : ''}">
            <i class="material-icons" style="color:var(--primary);flex-shrink:0;">${f?.icon ?? 'label'}</i>
            <div style="flex:1;min-width:0;">
                <div style="font-weight:600;font-size:.88rem;">${f?.label ?? m.dbField}</div>
                <div style="font-size:.75rem;color:#9e9e9e;">${lineInfo}</div>
            </div>
            <button type="button" class="del-btn" onclick="removeMapping('${m.dbField}')">
                <i class="material-icons">close</i>
            </button>
        </div>`;
    }).join('');
    document.getElementById('mappingCount').textContent = mappings.length;
}

function removeMapping(field) {
    mappings = mappings.filter(m => m.dbField !== field);
    renderAllMappings();
    syncHidden();
    refreshSpanHighlights();
}

function syncHidden() {
    document.getElementById('fieldMappingsInput').value = JSON.stringify(mappings);
}

// ── Span highlights ───────────────────────────────────────────────────────────
function refreshSpanHighlights() {
    // Build maps: lineIndex → {isPartial}
    const wholeLines   = new Set();
    const partialLines = new Set();
    mappings.forEach(m => {
        if (m.lineIndex == null) return;
        if (m.strategy === 'line_index_regex') partialLines.add(m.lineIndex);
        else wholeLines.add(m.lineIndex);
    });

    document.querySelectorAll('.textLayer span[data-line-index]').forEach(span => {
        const idx = parseInt(span.dataset.lineIndex);
        span.classList.remove('tl-assigned', 'tl-assigned-partial');
        if (wholeLines.has(idx))   span.classList.add('tl-assigned');
        if (partialLines.has(idx)) span.classList.add('tl-assigned-partial');
    });
}

// ── Drag & drop ───────────────────────────────────────────────────────────────
const dropZone = document.getElementById('pdfDropZone');
dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.style.borderColor = 'var(--primary)'; });
dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = ''; });
dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.style.borderColor = '';
    const f = e.dataTransfer.files[0];
    if (f && f.type === 'application/pdf') loadPdf(f);
});
</script>
{% endblock %}
