}
function closeBonFiche() {
    document.getElementById('bonModal').classList.remove('open');
    document.getElementById('bonModalFrame').src = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeBonFiche(); });

function onSubmit(e) {
    if (!selBon || !selEmpId) { e.preventDefault(); return false; }
    if (previewEvent) { previewEvent.remove(); previewEvent = null; }
    document.getElementById('btnCreate').disabled = true;
    document.getElementById('btnCreate').innerHTML = '<i class="material-icons">hourglass_empty</i> Création…';
    return true;
}

function onReoptimize(form) {
    const date = document.getElementById('dateInp').value;
    if (!date || !selEmpId) {
        showToast && showToast('warning', 'Sélectionnez une date et un employé d\'abord.');
        return false;
    }
    document.getElementById('rDate').value = date;
    document.getElementById('rEmp').value  = selEmpId;
    const btn = document.getElementById('btnReoptimize');
    btn.disabled = true;
    btn.innerHTML = '<i class="material-icons" style="font-size: 18px;">hourglass_empty</i> Calcul…';
    return true;
}

function updateReoptimizeBtn() {
    const date = document.getElementById('dateInp')?.value;
    const btn  = document.getElementById('btnReoptimize');
    if (btn) btn.disabled = !(date && selEmpId);
}

// ====== STATUS COLORS ======
const STATUS_COLORS = {
    'brouillon':    '#9c27b0',
    'à programmer': '#e65100',
    'programmé':    '#3f51b5',
    'en cours':     '#ff9800',
    'terminé':      '#2e7d32',
    'non effectué': '#d32f2f',
};

// ====== EMPLOYEE DAY VIEW ======
const EDV_SLOT_H  = 48;        // px per 30-min slot
const EDV_T_START = 7 * 60;    // 07:00 in minutes
const EDV_T_END   = 20 * 60;   // 20:00 in minutes
const EDV_SLOTS   = (EDV_T_END - EDV_T_START) / 30; // 26 slots

let edvDate = new Date();

function edvDateStr(d) {
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function edvFormatTitle(d) {
    return d.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
}
function edvMinToPx(min) { return ((min - EDV_T_START) / 30) * EDV_SLOT_H; }
function edvPadTime(h, m) { return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`; }

function edvPrev()  { edvDate.setDate(edvDate.getDate() - 1); refreshEdv(); }
function edvNext()  { edvDate.setDate(edvDate.getDate() + 1); refreshEdv(); }
function edvToday() { edvDate = new Date(); refreshEdv(); }
function edvGoTo(dateStr) {
    const [y,mo,d] = dateStr.split('-').map(Number);
    edvDate = new Date(y, mo - 1, d);
    refreshEdv();
}

function refreshEdv() {
    const date = edvDateStr(edvDate);
    document.getElementById('edvTitle').textContent = edvFormatTitle(edvDate);

    // Sync wizard date input
    const di = document.getElementById('dateInp');
    di.value = date;
    di.classList.add('filled');
    loadStats(date);

    const emps = Array.from(activeEmps);
    if (emps.length === 0) {
        buildEdvGrid(date, []);
        return;
    }

    document.getElementById('edvGrid').innerHTML =
        '<div class="edv-no-emp"><i class="material-icons">hourglass_empty</i>Chargement…</div>';

    const params = emps.map(id => `employes[]=${id}`).join('&');
    fetch(`/admin/planning/events?start=${date}T00:00:00&end=${date}T23:59:59&${params}`)
        .then(r => r.json())
        .then(evs => buildEdvGrid(date, evs))
        .catch(() => {
            document.getElementById('edvGrid').innerHTML =
                '<div class="edv-no-emp"><i class="material-icons">error_outline</i>Erreur de chargement</div>';
        });
}

function buildEdvGrid(date, events) {
    const activeList = EMPLOYES.filter(e => activeEmps.has(e.id));
    const grid = document.getElementById('edvGrid');

    if (activeList.length === 0) {
        grid.innerHTML = '<div class="edv-no-emp"><i class="material-icons">people_outline</i>Sélectionnez des techniciens dans le panneau gauche</div>';
        return;
    }

    // Group events by employee id
    const evsByEmp = {};
    activeList.forEach(e => { evsByEmp[e.id] = []; });
    events.forEach(ev => {
        const id = ev.extendedProps?.employeId;
        if (id && evsByEmp[id]) evsByEmp[id].push(ev);
    });

    const totalH = EDV_SLOTS * EDV_SLOT_H;
    const todayStr = edvDateStr(new Date());
    const isToday  = date === todayStr;

    // ---- Header row ----
    let headHtml = '<div class="edv-head-row"><div class="edv-head-gutter"></div>';
    activeList.forEach(e => {
        const load = empLoads[e.id] ?? 0;
        headHtml += `<div class="edv-head-cell" style="border-top:3px solid ${empColor(e.id)};">
            <div class="edv-emp-av" style="background:${empColor(e.id)}">${esc(e.nom[0].toUpperCase())}</div>
            <div>
                <div class="edv-emp-name">${esc(e.nom)}</div>
                <div class="edv-emp-sub" id="edvSub${e.id}">${load} prestation${load !== 1 ? 's' : ''}</div>
            </div>
        </div>`;
    });
    headHtml += '</div>';

    // ---- Time gutter ----
    let gutterHtml = `<div class="edv-body-gutter" style="height:${totalH}px;position:relative;">`;
    for (let i = 0; i <= EDV_SLOTS; i++) {
        const min = EDV_T_START + i * 30;
        if (min % 60 === 0) {
            gutterHtml += `<div class="edv-slot-label" style="top:${i * EDV_SLOT_H}px">${Math.floor(min/60)}:00</div>`;
        }
    }
    gutterHtml += '</div>';

    // ---- Employee columns ----
    let colsHtml = '';
    activeList.forEach(e => {
        colsHtml += `<div class="edv-emp-body" style="height:${totalH}px;" data-emp-id="${e.id}">`;

        // Background slots (clickable)
        for (let i = 0; i < EDV_SLOTS; i++) {
            const min = EDV_T_START + i * 30;
            const h = Math.floor(min / 60), m = min % 60;
            const isHalfHour = m === 30;
            colsHtml += `<div class="edv-bg-slot${isHalfHour ? ' edv-half-hour' : ''}"
                style="top:${i * EDV_SLOT_H}px;height:${EDV_SLOT_H}px;"
                data-date="${date}" data-time="${edvPadTime(h,m)}" data-emp-id="${e.id}"
                onclick="onEdvSlotClick(event,this)"></div>`;
        }

        // Events
        (evsByEmp[e.id] || []).forEach(ev => {
            const start   = new Date(ev.start);
            const end     = ev.end ? new Date(ev.end) : new Date(start.getTime() + 30 * 60000);
            const startMin = start.getHours() * 60 + start.getMinutes();
            const endMin   = end.getHours()   * 60 + end.getMinutes();
            const top      = edvMinToPx(startMin);
            const height   = Math.max(edvMinToPx(endMin) - top, 20);

            if (top >= edvMinToPx(EDV_T_END) || edvMinToPx(endMin) <= 0) return;

            const isTrajet = ev.extendedProps?.isTrajet;
            const statut   = ev.extendedProps?.statut;
            let bg = '', cls = 'edv-event', textC = 'white';

            if (isTrajet) {
                bg    = hexToRgba(empColor(e.id), 0.28);
                textC = '#555';
                cls  += ' edv-trajet';
            } else {
                bg = STATUS_COLORS[statut] || empColor(e.id);
                if (statut === 'brouillon') { cls += ' edv-brouillon'; bg = hexToRgba('#9c27b0', 0.75); }
            }

            const safeData = isTrajet ? '' : encodeURIComponent(JSON.stringify(ev));
            const startFmt = start.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
            const clickAttr = isTrajet ? '' : `data-ev="${safeData}" onclick="onEdvEventClick(event,this)"`;
            colsHtml += `<div class="${cls}"
                style="top:${Math.max(0,top)}px;height:${height}px;background:${bg};color:${textC};"
                ${clickAttr}>`;
            if (isTrajet) {
                colsHtml += `<i class="material-icons" style="font-size:10px;flex-shrink:0;">directions_car</i> ${ev.extendedProps.dureeTrajetMinutes} min`;
            } else {
                colsHtml += `<div style="overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">${esc(statut === 'brouillon' ? '✏ ' + ev.title : ev.title)}</div>`;
                if (height > 30) colsHtml += `<div style="font-size:0.67rem;opacity:0.85;">${startFmt}</div>`;
            }
            colsHtml += '</div>';
        });

        // Current time indicator
        if (isToday) {
            const now = new Date();
            const nowMin = now.getHours() * 60 + now.getMinutes();
            if (nowMin >= EDV_T_START && nowMin <= EDV_T_END) {
                colsHtml += `<div class="edv-now-line" style="top:${edvMinToPx(nowMin)}px;"></div>`;
            }
        }

        colsHtml += '</div>';
    });

    grid.innerHTML = `<div class="edv-grid-inner">
        ${headHtml}
        <div class="edv-body-row">${gutterHtml}${colsHtml}</div>
    </div>`;
}

function onEdvSlotClick(ev, el) {
    ev.stopPropagation();
    const date = el.dataset.date;
    const time = el.dataset.time;
    const empId = +el.dataset.empId;

    const di = document.getElementById('dateInp');
    di.value = date;
    di.classList.add('filled');
    document.getElementById('timeInp').value = time;

    if (!selEmpId || selEmpId !== empId) {
        const emp = EMPLOYES.find(e => e.id === empId);
        if (emp) pickEmp(emp.id, emp.nom);
    }
    refreshSummary();
    document.querySelector('.wizard-body').scrollTop = 0;
}

function onEdvEventClick(ev, el) {
    ev.stopPropagation();
    closePop();
    try {
        const raw = JSON.parse(decodeURIComponent(el.dataset.ev));
        const pseudo = {
            title:           raw.title,
            start:           raw.start ? new Date(raw.start) : null,
            end:             raw.end   ? new Date(raw.end)   : null,
            backgroundColor: STATUS_COLORS[raw.extendedProps?.statut] || empColor(raw.extendedProps?.employeId ?? 0),
            extendedProps:   raw.extendedProps || {},
        };
        showPop(pseudo, el, ev);
    } catch(e) { console.error(e); }
}

function updateEdvSubtitles() {
    EMPLOYES.forEach(e => {
        const sub = document.getElementById(`edvSub${e.id}`);
        if (sub) {
            const n = empLoads[e.id] ?? 0;
            sub.textContent = `${n} prestation${n !== 1 ? 's' : ''}`;
        }
    });
}

// ====== POPOVER ======
function showPop(event, el, jsEvent) {
    const p = event.extendedProps;
    document.getElementById('popDot').style.background = event.backgroundColor || '#999';
    document.getElementById('popTitle').textContent = event.title;
    const time = event.start?.toLocaleTimeString('fr-FR', { hour:'2-digit', minute:'2-digit' }) ?? '';
    const sc = 's-' + (p.statut || '').replace(/ /g, '-');
    const dureeStr = p.dureeMinutes ? `${p.dureeMinutes} min` : '';
    const trajetStr = (p.dureeTrajetMinutes != null && p.dureeTrajetMinutes > 0)
        ? `Trajet : ${p.dureeTrajetMinutes} min`
        : '';
    const geoRow = (p.geocoded === false)
        ? `<div class="ev-pop-row" style="color:#d32f2f"><i class="material-icons" style="color:#d32f2f">location_off</i>Adresse non géolocalisée</div>`
        : (p.geocoded === true ? `<div class="ev-pop-row" style="color:#2e7d32"><i class="material-icons" style="color:#2e7d32">location_on</i>Adresse géolocalisée</div>` : '');
    const overrideRow = p.adresseOverride
        ? `<div class="ev-pop-row" style="color:#f57f17"><i class="material-icons" style="color:#f57f17">edit_location</i>GPS corrigé : ${esc(p.adresseOverride)}</div>`
        : '';
    document.getElementById('popBody').innerHTML = `
        <div class="ev-pop-row"><i class="material-icons">engineering</i>${esc(p.employeNom)}</div>
        <div class="ev-pop-row"><i class="material-icons">schedule</i>${esc(time)}${dureeStr ? ' · ' + esc(dureeStr) : ''}</div>
        ${trajetStr ? `<div class="ev-pop-row"><i class="material-icons">directions_car</i>${esc(trajetStr)}</div>` : ''}
        ${p.creneauLabel ? `<div class="ev-pop-row"><i class="material-icons">light_mode</i>${esc(p.creneauLabel)}</div>` : ''}
        ${p.clientAdresse ? `<div class="ev-pop-row"><i class="material-icons">place</i>${esc(p.clientAdresse)}</div>` : ''}
        ${geoRow}
        ${overrideRow}
        ${p.typePrestation ? `<div class="ev-pop-row"><i class="material-icons">category</i>${esc(p.typePrestation)}</div>` : ''}
        <div class="ev-pop-row"><i class="material-icons">circle</i><span class="s-badge ${sc}">${esc(p.statutLabel || p.statut)}</span></div>`;
    const prefill = (p.adresseOverride || p.clientAdresse || '').replace(/'/g, "\\'");
    const regeocodeBtn = p.bonId
        ? `<button onclick="regeocodeBon(${p.bonId}, '${prefill}')" class="ev-pop-btn btn-view" title="Corriger l'adresse pour le géocodage"><i class="material-icons">my_location</i>Géocoder</button>`
        : '';
    const validateBrouillonBtn = p.statut === 'brouillon' && p.employeId
        ? `<button onclick="validateTourneeFromPop(${p.employeId})" class="ev-pop-btn" style="background:#7b1fa2;color:#fff;"><i class="material-icons">check_circle</i>Valider</button>`
        : '';
    document.getElementById('popActions').innerHTML = `
        <a href="/admin/bon-commande/${p.bonId}" class="ev-pop-btn btn-view"><i class="material-icons">open_in_new</i>Voir bon</a>
        ${validateBrouillonBtn}
        ${regeocodeBtn}
        <button onclick="delPrestation(${p.prestationId})" class="ev-pop-btn btn-del"><i class="material-icons">delete</i>Supprimer</button>`;

    const pop = document.getElementById('evPop');
    pop.classList.add('open');
    const rect = el.getBoundingClientRect();
    let left = rect.right + 10, top = rect.top;
    if (left + 310 > window.innerWidth) left = rect.left - 310;
    if (top + 280 > window.innerHeight) top = window.innerHeight - 290;
    pop.style.left = Math.max(4, left) + 'px';
    pop.style.top  = Math.max(4, top)  + 'px';
}
function closePop() { document.getElementById('evPop').classList.remove('open'); }

async function validateTourneeFromPop(empId) {
    const date = document.getElementById('dateInp').value || new Date().toISOString().slice(0,10);
    if (!confirm('Valider toutes les prestations en brouillon pour ce technicien ce jour ?')) return;
    closePop();
    const r = await fetch('/admin/planning/validate-tournee', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
        body: JSON.stringify({ employeId: empId, date }),
    });
    const data = await r.json().catch(() => ({}));
    showToast(r.ok ? 'success' : 'error', data.message ?? data.error ?? 'Erreur');
    if (r.ok) {
        refreshEdv();
        if (selEmpId === empId) {
            await loadCapacite();
            doSearch();
            updateBrouillonIndicator();
        }
    }
}

function delPrestation(id) {
    if (!confirm('Supprimer cette intervention ?')) return;
    const f = document.createElement('form');
    f.method = 'post';
    f.action = `/admin/planning/delete-prestation/${id}`;
    document.body.appendChild(f);
    f.submit();
}

async function regeocodeBon(bonId, currentAddr) {
    if (!bonId) return;
    // Offer to correct the address (e.g. "rue" → "avenue") without modifying the bon itself.
    const typed = prompt(
        'Adresse à géocoder (laissez vide pour utiliser celle du bon) :\n'
        + 'Ex : « 45 avenue Jean Jaurès 59000 Lille »',
        currentAddr || ''
    );
    if (typed === null) return; // cancelled
    const fd = new FormData();
    fd.append('override_address', typed);
    try {
        const r = await fetch(`/admin/planning/geocode-bon/${bonId}`, { method: 'POST', body: fd });
        const data = await r.json();
        if (data.ok) {
            alert('Adresse géocodée : ' + data.latitude + ', ' + data.longitude
                + (data.adresseOverride ? `\n(Override enregistré : ${data.adresseOverride})` : ''));
            closePop();
            refreshEdv();
        } else {
            alert('Géocodage impossible. Vérifiez l\'orthographe (rue/avenue/bd) et le code postal.');
        }
    } catch (e) {
        alert('Erreur de géocodage : ' + e.message);
    }
}

document.addEventListener('click', e => {
    const pop = document.getElementById('evPop');
    if (pop.classList.contains('open') && !pop.contains(e.target)) closePop();
});

// ====== INIT ======
document.addEventListener('DOMContentLoaded', () => {
    renderEmpPanel();

    // Initialise the date from wizard input or today
    const di = document.getElementById('dateInp');
    if (di.value) {
        const [y,mo,d] = di.value.split('-').map(Number);
        edvDate = new Date(y, mo - 1, d);
        di.classList.add('filled');
    }

    refreshEdv();
});
</script>
{% endblock %}
