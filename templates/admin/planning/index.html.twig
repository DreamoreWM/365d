<script>
// ====== CONFIG ======
const EMPLOYES = [{% for e in employes %}{ id:{{ e.id }}, nom:{{ e.nom|json_encode|raw }} },{% endfor %}];
const COLORS   = ['#e91e63','#9c27b0','#673ab7','#3f51b5','#2196f3','#009688','#4caf50','#ff9800','#ff5722','#795548','#607d8b','#00bcd4'];
const empColor = id => COLORS[id % COLORS.length];

// Converts a 6-digit hex color to rgba with a given alpha (0–1)
function hexToRgba(hex, alpha) {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r},${g},${b},${alpha})`;
}

// Inject avatar colors
const _cs = document.createElement('style');
EMPLOYES.forEach(e => { _cs.textContent += `[data-empid="${e.id}"] { background: ${empColor(e.id)} !important; }`; });
document.head.appendChild(_cs);

// ====== CSRF ======
const CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.content ?? '';

// ====== STATE ======
let selBon    = null;
let selEmpId  = null;
let selEmpNom = null;
let activeEmps = new Set(EMPLOYES.map(e => e.id));
let statut         = 'à programmer';
let groupe         = '';
let typePrestation = '';
let empLoads  = {};
let searchTm     = null;
let bonCache     = [];  // { id, ...data }
let previewEvent = null;
let isBrouillon  = false;  // mode brouillon
let capaciteData = null;   // { matinDisponible, apremDisponible, ... }

// ====== UTILS ======
function esc(s) { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }
function showToast(type, msg) {
    const t = document.createElement('div');
    const cls = type === 'success' ? 't-success' : (type === 'danger' || type === 'error') ? 't-error' : 't-info';
    const icon = type === 'success' ? 'check_circle' : 'info';
    t.className = `toast ${cls}`;
    t.innerHTML = `<i class="material-icons">${icon}</i>${esc(msg)}`;
    document.getElementById('toasts').appendChild(t);
    setTimeout(() => t.remove(), 4500);
}

// ====== EMPLOYEE LEFT PANEL ======
function renderEmpPanel() {
    document.getElementById('empList').innerHTML = EMPLOYES.map(e => `
        <div class="emp-item ${activeEmps.has(e.id) ? '' : 'inactive'}" onclick="toggleEmp(${e.id})">
            <div class="emp-avatar" style="background:${empColor(e.id)};">${esc(e.nom[0].toUpperCase())}</div>
            <span class="emp-name">${esc(e.nom)}</span>
            <span class="emp-day-count" id="cnt${e.id}">${empLoads[e.id] ?? 0}</span>
        </div>
    `).join('');
}
function toggleEmp(id) {
    if (activeEmps.has(id)) activeEmps.delete(id); else activeEmps.add(id);
    renderEmpPanel();
    refreshEdv();
}
function setAllEmp(all) {
    EMPLOYES.forEach(e => all ? activeEmps.add(e.id) : activeEmps.delete(e.id));
    renderEmpPanel();
    refreshEdv();
}

// ====== STATS (load counts per employee for a date) ======
function loadStats(date) {
    fetch(`/admin/planning/stats?date=${date}`)
        .then(r => r.json())
        .then(data => {
            empLoads = {};
            (data.chargeEmployes || []).forEach(r => { empLoads[r.id] = +r.nombre_prestations; });
            // Update left panel counts
            EMPLOYES.forEach(e => {
                const el = document.getElementById(`cnt${e.id}`);
                if (el) el.textContent = empLoads[e.id] ?? 0;
                const wl = document.getElementById(`eload${e.id}`);
                if (wl) {
                    const n = empLoads[e.id] ?? 0;
                    wl.textContent = n ? `${n} ce jour` : 'Libre';
                    wl.style.color = n > 3 ? '#ef5350' : n > 0 ? '#ff9800' : '#4caf50';
                }
            });
            // Update EDV column subtitles
            updateEdvSubtitles();
        })
        .catch(() => {});
}

// ====== SEARCH ======
function debSearch() { clearTimeout(searchTm); searchTm = setTimeout(doSearch, 280); }

function setStatut(btn, val) {
    statut = val;
    document.querySelectorAll('#statutChips .chip').forEach(b => b.classList.toggle('active', b.dataset.s === val));
    bonCache.length ? showFiltered() : doSearch();
}
function setGroupe(btn, val) {
    groupe = val;
    document.querySelectorAll('#geoChips .chip').forEach(b => b.classList.toggle('active', b.dataset.g === val));
    bonCache.length ? showFiltered() : doSearch();
}
function setTypePrestation(btn, val) {
    typePrestation = val;
    document.querySelectorAll('#typeChips .chip').forEach(b => b.classList.toggle('active', b.dataset.t === val));
    bonCache.length ? showFiltered() : doSearch();
}

function doSearch() {
    if (!selEmpId) return; // Require employee selection first
    const q    = document.getElementById('wizSearch').value.trim();
    const date = document.getElementById('dateInp').value;
    const p    = new URLSearchParams({ q, statut: '', groupe_geo: '', type_prestation: '', all: '1',
                                       employe: selEmpId ?? '', date: date ?? '' });
    document.getElementById('bonList').innerHTML = '<div class="search-msg"><i class="material-icons">hourglass_empty</i>Recherche…</div>';
    fetch(`/admin/planning/search-bons?${p}`)
        .then(r => r.json())
        .then(allBons => {
            bonCache = allBons;
            updateChipCounts(allBons);
            showFiltered();
        })
        .catch(() => { document.getElementById('bonList').innerHTML = '<div class="search-msg">Erreur de chargement</div>'; });
}

function showFiltered() {
    let bons = bonCache;
    if (statut)         bons = bons.filter(b => b.statut === statut);
    if (groupe)         bons = bons.filter(b => String(b.groupeGeo?.id ?? '') === String(groupe));
    if (typePrestation) bons = bons.filter(b => String(b.typePrestation?.id ?? '') === String(typePrestation));
    // If capacity filter is active and capacity is known, filter by fits
    const filterCb = document.getElementById('filterByCapacity');
    if (filterCb?.checked && capaciteData) {
        bons = bons.filter(b => b.fitsAnySlot !== false);
    }
    showResults(bons);
}

function updateChipCounts(bons) {
    function setBadges(selector, keyFn) {
        const counts = {};
        bons.forEach(b => { const k = keyFn(b); if (k != null) counts[k] = (counts[k] || 0) + 1; });
        document.querySelectorAll(selector + ' .chip').forEach(chip => {
            const key = [...chip.attributes].find(a => a.name.startsWith('data-'))?.value ?? '';
            const n = key === '' ? bons.length : (counts[key] || 0);
            let cnt = chip.querySelector('.chip-cnt');
            if (!cnt) { cnt = document.createElement('span'); cnt.className = 'chip-cnt'; chip.appendChild(cnt); }
            cnt.textContent = n > 99 ? '99+' : n;
            cnt.style.display = '';
        });
    }
    setBadges('#statutChips',  b => b.statut);
    setBadges('#geoChips',     b => b.groupeGeo ? String(b.groupeGeo.id) : null);
    setBadges('#typeChips',    b => b.typePrestation ? String(b.typePrestation.id) : null);
}

function showResults(bons) {
    const el = document.getElementById('bonList');
    if (!bons.length) {
        el.innerHTML = '<div class="search-msg"><i class="material-icons">search_off</i>Aucun résultat</div>';
        return;
    }
    el.innerHTML = bons.slice(0, 40).map(b => {
        const progText = b.nombrePrestationsNecessaires > 0 ? `${b.nombrePrestations}/${b.nombrePrestationsNecessaires}` : '';
        const geoIcon = (b.geocoded === false)
            ? `<i class="material-icons" title="Adresse non géolocalisée" style="font-size:13px;vertical-align:middle;color:#d32f2f">location_off</i>`
            : (b.geocoded === true ? `<i class="material-icons" title="Adresse géolocalisée" style="font-size:13px;vertical-align:middle;color:#2e7d32">location_on</i>` : '');
        // Capacity fit badge
        let fitBadge = '';
        if (capaciteData && b.fitsAnySlot !== null && b.fitsAnySlot !== undefined) {
            const dur = b.dureeMinutes ?? 30;
            if (b.fitsAnySlot) {
                const slots = [];
                if (b.fitsMatin) slots.push('matin');
                if (b.fitsAprem) slots.push('aprem');
                fitBadge = `<span class="fits-badge fits-ok" title="${dur} min — tient dans : ${slots.join(', ')}"><i class="material-icons" style="font-size:10px;">check</i> ${dur} min</span>`;
            } else {
                fitBadge = `<span class="fits-badge fits-no" title="${dur} min — ne tient pas dans les créneaux disponibles"><i class="material-icons" style="font-size:10px;">block</i> ${dur} min</span>`;
            }
        }
        return `<div class="bon-card" onclick="pickBon(${b.id})">
            <div class="bon-name">${esc(b.clientNom)} ${geoIcon}</div>
            <div class="bon-addr"><i class="material-icons" style="font-size:11px;vertical-align:middle;">place</i> ${esc(b.clientAdresse)}</div>
            <div class="bon-meta">
                <span class="b-badge b-bc">BC #${esc(b.numeroCommande)}</span>
                ${progText ? `<span class="b-badge b-prog">${progText} interv.</span>` : ''}
                ${b.typePrestation ? `<span class="b-badge b-type">${esc(b.typePrestation.nom)}</span>` : ''}
                ${b.groupeGeo ? `<span class="b-badge b-geo">${esc(b.groupeGeo.nom)}</span>` : ''}
                ${fitBadge}
            </div>
        </div>`;
    }).join('');
}

// ====== WIZARD STEPS ======

// STEP 1: Employee picked first
function pickEmp(id, nom) {
    if (selEmpId) document.getElementById(`eb${selEmpId}`)?.classList.remove('selected');
    selEmpId = id; selEmpNom = nom;
    updateReoptimizeBtn && updateReoptimizeBtn();
    document.getElementById(`eb${id}`)?.classList.add('selected');
    document.getElementById('s1text').textContent = nom;
    document.getElementById('wStep1').classList.replace('active','done');
    document.getElementById('wStep2').classList.add('active');
    document.querySelector('.wizard-body').scrollTop = 0;
    // Load capacity for this employee + current date and refresh search with employee filter
    loadCapacite().then(() => doSearch());
    updateBrouillonIndicator();
    refreshSummary();
}

// STEP 2: Bon picked
function pickBon(id) {
    const b = bonCache.find(x => x.id === id);
    if (!b) return;
    selBon = b;

    // Show selected card
    document.getElementById('selBonName').textContent = b.clientNom;
    document.getElementById('selBonAddr').textContent = b.clientAdresse;
    const prog = b.nombrePrestationsNecessaires > 0 ? `${b.nombrePrestations}/${b.nombrePrestationsNecessaires}` : '';
    document.getElementById('selBonMeta').innerHTML = `
        <span class="b-badge b-bc">BC #${esc(b.numeroCommande)}</span>
        ${prog ? `<span class="b-badge b-prog">${prog} interv.</span>` : ''}
        ${b.typePrestation ? `<span class="b-badge b-type">${esc(b.typePrestation.nom)}</span>` : ''}`;
    document.getElementById('selBonBox').style.display = 'flex';
    document.getElementById('searchArea').style.display = 'none';

    // Mark step 2 done, activate step 3
    document.getElementById('s2text').textContent = b.clientNom;
    document.getElementById('wStep2').classList.replace('active','done');
    document.getElementById('wStep3').classList.add('active');
    document.querySelector('.wizard-body').scrollTop = 999;

    // Queue time after existing prestations if half-day slot already selected
    if (currentSlot === 'matin' || currentSlot === 'aprem') {
        computeNextSlotTime(currentSlot).then(next => {
            document.getElementById('timeInp').value = next;
            refreshSummary();
            checkFixeConflict();
        });
    } else {
        refreshSummary();
        checkFixeConflict();
    }
}

function resetBon() {
    selBon = null;
    if (previewEvent) { previewEvent.remove(); previewEvent = null; }
    document.getElementById('selBonBox').style.display = 'none';
    document.getElementById('searchArea').style.display = 'block';
    document.getElementById('wStep2').classList.remove('done');
    document.getElementById('wStep2').classList.add('active');
    document.getElementById('wStep3').classList.remove('active','done');
    document.getElementById('s2badge').style.display = 'none';
    refreshSummary();
    document.getElementById('wizSearch').focus();
}

function updateCalendarPreview() {
    // Preview handled inline in the EDV grid; no-op here.
    previewEvent = null;
}

function onDateChange() {
    const inp = document.getElementById('dateInp');
    const d = inp.value;
    inp.classList.toggle('filled', !!d);
    if (d) { loadStats(d); edvGoTo(d); }
    // Reload capacity when date changes (if employee already selected)
    if (selEmpId) {
        loadCapacite().then(() => doSearch());
        updateBrouillonIndicator();
