    // Keep the auto-queued hour in sync when the day changes.
    if (d && selEmpId && (currentSlot === 'matin' || currentSlot === 'aprem')) {
        computeNextSlotTime(currentSlot).then(next => {
            document.getElementById('timeInp').value = next;
            refreshSummary();
            checkFixeConflict();
        });
    } else {
        refreshSummary();
        checkFixeConflict();
    }
}
// ====== SLOT HANDLING (Matin 9-12 / Après-midi 12-15 / Heure fixe) ======
// currentSlot reflects which half-day the user is placing the intervention in.
// null means no preference yet; 'fixe' means manual entry.
let currentSlot = null;
const SLOT_RANGES = {
    matin: { start: '09:00', end: '12:00' },
    aprem: { start: '12:00', end: '15:00' },
};

function updateSlotButtons() {
    ['matin','aprem','fixe'].forEach(s => {
        const el = document.getElementById('slot' + s.charAt(0).toUpperCase() + s.slice(1));
        if (el) el.classList.toggle('active', currentSlot === s);
    });
    const info = document.getElementById('slotOptInfo');
    if (info) info.style.display = (currentSlot === 'matin' || currentSlot === 'aprem') ? 'flex' : 'none';
}

function hmToMin(hm) { const [h,m] = hm.split(':').map(Number); return h*60 + m; }
function minToHm(mn) { const h = Math.floor(mn/60), m = mn%60; return String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0'); }

function setSlot(slot) {
    currentSlot = slot;
    updateSlotButtons();
    if (slot === 'fixe') {
        const t = document.getElementById('timeInp');
        t.focus();
        if (typeof t.showPicker === 'function') { try { t.showPicker(); } catch(_) {} }
        checkFixeConflict();
        return;
    }
    computeNextSlotTime(slot).then(next => {
        document.getElementById('timeInp').value = next;
        refreshSummary();
        checkFixeConflict();
    });
}

// When currentSlot='fixe', delegate to the server to check whether the chosen time
// leaves enough room (durée prestation + trajet) around the other fixed rdvs of the day.
// Shows a warning with the earliest possible time and blocks the create button.
let fixeConflict = false;
let fixeCheckSeq = 0;
function checkFixeConflict() {
    const warnEl = document.getElementById('fixeConflictWarn');
    const wasConflict = fixeConflict;
    fixeConflict = false;
    if (warnEl) warnEl.style.display = 'none';

    const date  = document.getElementById('dateInp').value;
    const heure = document.getElementById('timeInp').value;
    const ready = selBon && selEmpId && date && heure;

    if (currentSlot !== 'fixe' || !ready) {
        if (wasConflict) document.getElementById('btnCreate').disabled = !ready;
        return;
    }

    const seq = ++fixeCheckSeq;
    const url = `/admin/planning/fixe-check?bon=${encodeURIComponent(selBon.id)}`
              + `&employe=${encodeURIComponent(selEmpId)}`
              + `&date=${encodeURIComponent(date)}`
              + `&heure=${encodeURIComponent(heure)}`;
    fetch(url)
        .then(r => r.ok ? r.json() : { ok: true })
        .then(data => {
            if (seq !== fixeCheckSeq) return; // a newer request superseded this one
            if (data && data.ok === false) {
                fixeConflict = true;
                if (warnEl) {
                    warnEl.style.display = 'flex';
                    warnEl.querySelector('.fc-warn-msg').textContent = data.message
                        || 'Créneau indisponible à cette heure.';
                }
                document.getElementById('btnCreate').disabled = true;
            } else if (wasConflict) {
                document.getElementById('btnCreate').disabled = !ready;
            }
        })
        .catch(() => {});
}

// Finds the next free start time in the chosen half-day for the selected date/employee,
// placing the new intervention right after the last one in that range.
// Falls back to the range start when no date/employee yet or the fetch fails.
function computeNextSlotTime(slot) {
    const range = SLOT_RANGES[slot];
    const date  = document.getElementById('dateInp').value;
    if (!date || !selEmpId) return Promise.resolve(range.start);

    const url = `/admin/planning/events?start=${date}T00:00:00&end=${date}T23:59:59&employes[]=${encodeURIComponent(selEmpId)}`;
    return fetch(url)
        .then(r => r.ok ? r.json() : [])
        .then(evs => {
            const rangeStartMin = hmToMin(range.start);
            const rangeEndMin   = hmToMin(range.end);
            let cursor = rangeStartMin;
            let lastTrajetMin = 0;
            (evs || []).forEach(e => {
                if (e.extendedProps?.isTrajet) return; // ignorer les blocs de trajet
                const s = (e.start || '').slice(11,16);
                const en = (e.end   || '').slice(11,16);
                if (!s) return;
                const sMin = hmToMin(s);
                const eMin = en ? hmToMin(en) : sMin + 60;
                if (sMin >= rangeStartMin && sMin < rangeEndMin && eMin > cursor) {
                    cursor = eMin;
                    // Keep the travel time of the last event in the slot as a proxy for
                    // the travel time from that location to the next (new) prestation.
                    lastTrajetMin = e.extendedProps?.dureeTrajetMinutes ?? 0;
                }
            });
            // When there are existing events, add an estimated travel time to the new
            // prestation so the pre-fill matches more closely what the optimizer will produce.
            if (cursor > rangeStartMin) {
                cursor += Math.max(lastTrajetMin, 5);
            }
            if (cursor >= rangeEndMin) {
                showToast('info', slot === 'matin'
                    ? 'Le créneau du matin est complet — ajustez l\'heure manuellement.'
                    : 'Le créneau de l\'après-midi est complet — ajustez l\'heure manuellement.');
                cursor = rangeEndMin;
            } else {
                // Warn if adding the new prestation (with its duration) would overflow the slot.
                const newDur = selBon?.dureeMinutes ?? 30;
                if (cursor + newDur > rangeEndMin) {
                    showToast('warning', slot === 'matin'
                        ? `Attention : cette prestation (${newDur} min) déborderait sur la pause déjeuner (fin estimée ${minToHm(cursor + newDur)}).`
                        : `Attention : cette prestation (${newDur} min) dépasserait la fin de journée (fin estimée ${minToHm(cursor + newDur)}).`);
                }
            }
            return minToHm(cursor);
        })
        .catch(() => range.start);
}

function onTimeChange() {
    const hm = document.getElementById('timeInp').value;
    if (hm) {
        // Explicit "Heure fixe" sticks — the user wants this time pinned, even if it happens
        // to fall inside matin/aprem range. Otherwise derive slot from time-of-day.
        if (currentSlot !== 'fixe') {
            const m = hmToMin(hm);
            if      (m >= hmToMin(SLOT_RANGES.matin.start) && m < hmToMin(SLOT_RANGES.matin.end)) currentSlot = 'matin';
            else if (m >= hmToMin(SLOT_RANGES.aprem.start) && m < hmToMin(SLOT_RANGES.aprem.end)) currentSlot = 'aprem';
            else currentSlot = 'fixe';
        }
        updateSlotButtons();
    }
    refreshSummary();
    checkFixeConflict();
}

function setToday() {
    const t = new Date().toISOString().slice(0,10);
    document.getElementById('dateInp').value = t;
    onDateChange();
}

function refreshSummary() {
    const date  = document.getElementById('dateInp').value;
    const heure = document.getElementById('timeInp').value;
    document.getElementById('fBon').value     = selBon?.id ?? '';
    document.getElementById('fEmp').value     = selEmpId ?? '';
    document.getElementById('fDate').value    = date;
    document.getElementById('fHeure').value   = heure;
    // Empty means "infer from time" server-side — only send an explicit value
    // when the user actually clicked a slot button (or its equivalent).
    document.getElementById('fCreneau').value = currentSlot ?? '';
    document.getElementById('fNote').value    = document.getElementById('noteInp')?.value ?? '';
    document.getElementById('fMode').value    = isBrouillon ? 'brouillon' : '';
    updateCalendarPreview();

    const ready = selBon && selEmpId && date && heure;
    document.getElementById('btnCreate').disabled = !ready || fixeConflict;

    // Update create button label based on mode
    const icon  = document.getElementById('btnCreateIcon');
    const label = document.getElementById('btnCreateLabel');
    if (isBrouillon) {
        if (icon)  icon.textContent  = 'edit_note';
        if (label) label.textContent = 'Ajouter au brouillon';
        if (document.getElementById('btnCreate')) {
            document.getElementById('btnCreate').style.background = '#7b1fa2';
        }
    } else {
        if (icon)  icon.textContent  = 'add_circle';
        if (label) label.textContent = 'Créer l\'intervention';
        if (document.getElementById('btnCreate')) {
            document.getElementById('btnCreate').style.background = '';
        }
    }

    const box = document.getElementById('confirmBox');
    if (ready) {
        const df = new Date(date + 'T12:00').toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' });
        const brouillonRow = isBrouillon ? `<div class="c-row" style="color:#7b1fa2"><i class="material-icons">edit_note</i><strong>Mode brouillon</strong> — à valider avant publication</div>` : '';
        box.className = 'confirm-summary visible';
        box.innerHTML = `
            <div class="c-row"><i class="material-icons">person</i><strong>${esc(selBon.clientNom)}</strong></div>
            <div class="c-row"><i class="material-icons">place</i>${esc(selBon.clientAdresse)}</div>
            <div class="c-row"><i class="material-icons">engineering</i><strong>${esc(selEmpNom)}</strong></div>
            <div class="c-row"><i class="material-icons">schedule</i>${esc(df)} à <strong>${esc(heure)}</strong></div>
            ${brouillonRow}`;
    } else {
        box.className = 'confirm-summary';
    }
}

// ====== GO BACK IN STEPS ======
function goToStep(n) {
    const step = document.getElementById(`wStep${n}`);
    if (!step.classList.contains('done')) return; // only act if already done
    if (n === 1) {
        // Reset employee selection
        if (selEmpId) document.getElementById(`eb${selEmpId}`)?.classList.remove('selected');
        selEmpId = null; selEmpNom = null;
        selBon   = null;
        if (previewEvent) { previewEvent.remove(); previewEvent = null; }
        capaciteData = null;
        document.getElementById('capacitySection').style.display = 'none';
        document.getElementById('capacityFilter').style.display = 'none';
        document.getElementById('selBonBox').style.display = 'none';
        document.getElementById('searchArea').style.display = 'block';
        document.getElementById('wStep1').classList.remove('done');
        document.getElementById('wStep1').classList.add('active');
        document.getElementById('wStep2').classList.remove('active','done');
        document.getElementById('wStep3').classList.remove('active','done');
        document.getElementById('s1badge').style.display = 'none';
        document.getElementById('s2badge').style.display = 'none';
        document.getElementById('bonList').innerHTML = '<div class="search-msg"><i class="material-icons">person</i>Sélectionnez un technicien d\'abord</div>';
        updateBrouillonIndicator();
        refreshSummary();
        return;
    }
    if (n === 2) { resetBon(); return; }
}

