// ====== CAPACITY ======
function loadCapacite() {
    const date = document.getElementById('dateInp').value;
    if (!selEmpId || !date) {
        capaciteData = null;
        document.getElementById('capacitySection').style.display = 'none';
        document.getElementById('capacityFilter').style.display = 'none';
        return Promise.resolve(null);
    }
    return fetch(`/admin/planning/capacite-jour?employe=${encodeURIComponent(selEmpId)}&date=${encodeURIComponent(date)}`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            capaciteData = data;
            renderCapacityBars(data);
            return data;
        })
        .catch(() => { capaciteData = null; return null; });
}

function renderCapacityBars(data) {
    if (!data) {
        document.getElementById('capacitySection').style.display = 'none';
        document.getElementById('capacityFilter').style.display = 'none';
        return;
    }
    document.getElementById('capacitySection').style.display = 'block';
    document.getElementById('capacityFilter').style.display = 'flex';

    function barPct(used, total) { return total > 0 ? Math.min(100, Math.round(used / total * 100)) : 0; }
    function barClass(pct) { return pct >= 100 ? 'full' : pct >= 75 ? 'warn' : 'ok'; }

    const matinPct = barPct(data.matinUsed, data.matinTotal);
    const apremPct = barPct(data.apremUsed, data.apremTotal);

    const barMatin = document.getElementById('barMatin');
    const barAprem = document.getElementById('barAprem');
    barMatin.style.width = matinPct + '%';
    barMatin.className   = 'capacity-bar-fill ' + barClass(matinPct);
    barAprem.style.width = apremPct + '%';
    barAprem.className   = 'capacity-bar-fill ' + barClass(apremPct);

    function fmtMin(m) { return m >= 60 ? `${Math.floor(m/60)}h${m%60 ? String(m%60).padStart(2,'0') : ''}` : `${m} min`; }
    document.getElementById('txtMatin').textContent = `${fmtMin(data.matinDisponible)} libre`;
    document.getElementById('txtAprem').textContent = `${fmtMin(data.apremDisponible)} libre`;
}

// ====== BROUILLON INDICATOR ======
function updateBrouillonIndicator() {
    const date = document.getElementById('dateInp').value;
    if (!selEmpId || !date) {
        document.getElementById('brouillonIndicator').classList.remove('visible');
        return;
    }
    fetch(`/admin/planning/capacite-jour?employe=${encodeURIComponent(selEmpId)}&date=${encodeURIComponent(date)}`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            const ind = document.getElementById('brouillonIndicator');
            if (data && data.brouillonCount > 0) {
                document.getElementById('brouillonCount').textContent = data.brouillonCount;
                ind.classList.add('visible');
            } else {
                ind.classList.remove('visible');
            }
        })
        .catch(() => {});
}

async function validateTournee() {
    const date = document.getElementById('dateInp').value;
    if (!selEmpId || !date) return;
    if (!confirm('Valider toutes les prestations en brouillon pour ce technicien ce jour ?')) return;
    const r = await fetch('/admin/planning/validate-tournee', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
        body: JSON.stringify({ employeId: selEmpId, date }),
    });
    const data = await r.json().catch(() => ({}));
    if (r.ok) {
        showToast('success', data.message ?? 'Tournée validée');
        refreshEdv();
        await loadCapacite();
        doSearch();
        updateBrouillonIndicator();
    } else {
        showToast('error', data.error ?? 'Erreur');
    }
}

async function discardTournee() {
    const date = document.getElementById('dateInp').value;
    if (!selEmpId || !date) return;
    if (!confirm('Supprimer toutes les prestations en brouillon pour ce technicien ce jour ?')) return;
    const r = await fetch('/admin/planning/discard-tournee', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
        body: JSON.stringify({ employeId: selEmpId, date }),
    });
    const data = await r.json().catch(() => ({}));
    if (r.ok) {
        showToast('success', data.message ?? 'Brouillon supprimé');
        refreshEdv();
        await loadCapacite();
        doSearch();
        updateBrouillonIndicator();
    } else {
        showToast('error', data.error ?? 'Erreur');
    }
}

