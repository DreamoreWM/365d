<script>
// ==================== UTILITIES ====================
function moveCursor(cursor, x, y) {
    cursor.style.left = x + 'px';
    cursor.style.top = y + 'px';
}
function showCursor(cursor) { cursor.classList.add('visible'); }
function hideCursor(cursor) { cursor.classList.remove('visible'); }
function clickEffect(cursor) {
    cursor.classList.add('clicking');
    // Ripple
    const ripple = document.createElement('div');
    ripple.className = 'click-ripple';
    ripple.style.left = (parseInt(cursor.style.left) - 5) + 'px';
    ripple.style.top = (parseInt(cursor.style.top) + 5) + 'px';
    cursor.parentElement.appendChild(ripple);
    setTimeout(() => { cursor.classList.remove('clicking'); }, 200);
    setTimeout(() => ripple.remove(), 700);
}

function wait(ms) { return new Promise(r => setTimeout(r, ms)); }

function getRelativePos(el, frame) {
    const elR = el.getBoundingClientRect();
    const frR = frame.getBoundingClientRect();
    return { x: elR.left - frR.left + elR.width / 2, y: elR.top - frR.top + elR.height / 2 };
}

// ==================== PLANNING ANIMATION ====================
async function animatePlanning() {
    const frame = document.getElementById('planningFrame');
    const cursor = document.getElementById('planCursor');

    while (true) {
        // Reset all steps
        for (let i = 1; i <= 4; i++) {
            document.getElementById('wNum' + i).className = 'mock-step-num pending';
            document.getElementById('wLabel' + i).className = 'mock-step-label pending';
            document.getElementById('wBadge' + i).classList.remove('visible');
            document.getElementById('wStep' + i).classList.remove('highlight');
        }
        document.querySelectorAll('.mock-emp-item').forEach(e => e.classList.remove('selected'));
        document.querySelectorAll('.mock-cal-cell').forEach(e => e.classList.remove('highlighted'));
        const newEv = document.getElementById('newPlanEvent');
        if (newEv) newEv.remove();
        hideCursor(cursor);

        await wait(1200);
        showCursor(cursor);
        moveCursor(cursor, 300, 200);
        await wait(400);

        // Step 1: Select BC
        const s1 = getRelativePos(document.getElementById('wStep1'), frame);
        moveCursor(cursor, s1.x, s1.y);
        await wait(500);
        clickEffect(cursor);
        await wait(200);
        document.getElementById('wStep1').classList.add('highlight');
        document.getElementById('wNum1').className = 'mock-step-num active';
        document.getElementById('wLabel1').className = 'mock-step-label active';
        await wait(350);
        document.getElementById('wNum1').className = 'mock-step-num done';
        document.getElementById('wBadge1').classList.add('visible');
        document.getElementById('wStep1').classList.remove('highlight');
        await wait(400);

        // Step 2: Select employee (click on Dupont)
        const empPos = getRelativePos(document.getElementById('empDupont'), frame);
        moveCursor(cursor, empPos.x, empPos.y);
        await wait(500);
        clickEffect(cursor);
        await wait(200);
        document.getElementById('empDupont').classList.add('selected');
        document.getElementById('wStep2').classList.add('highlight');
        document.getElementById('wNum2').className = 'mock-step-num active';
        document.getElementById('wLabel2').className = 'mock-step-label active';
        await wait(350);
        document.getElementById('wNum2').className = 'mock-step-num done';
        document.getElementById('wBadge2').classList.add('visible');
        document.getElementById('wStep2').classList.remove('highlight');
        await wait(400);

        // Step 3: Select date (click on cell3 = Jeu)
        const cellPos = getRelativePos(document.getElementById('cell3'), frame);
        moveCursor(cursor, cellPos.x, cellPos.y);
        await wait(500);
        clickEffect(cursor);
        await wait(200);
        document.getElementById('cell3').classList.add('highlighted');
        document.getElementById('wStep3').classList.add('highlight');
        document.getElementById('wNum3').className = 'mock-step-num active';
        document.getElementById('wLabel3').className = 'mock-step-label active';
        await wait(350);
        document.getElementById('wNum3').className = 'mock-step-num done';
        document.getElementById('wBadge3').classList.add('visible');
        document.getElementById('wStep3').classList.remove('highlight');
        await wait(400);

        // Step 4: Confirm
        const s4 = getRelativePos(document.getElementById('wStep4'), frame);
        moveCursor(cursor, s4.x, s4.y);
        await wait(500);
        clickEffect(cursor);
        await wait(200);
        document.getElementById('wStep4').classList.add('highlight');
        document.getElementById('wNum4').className = 'mock-step-num active';
        document.getElementById('wLabel4').className = 'mock-step-label active';
        await wait(250);
        document.getElementById('wNum4').className = 'mock-step-num done';
        document.getElementById('wBadge4').classList.add('visible');

        // Add event to calendar
        document.getElementById('cell3').classList.remove('highlighted');
        const ev = document.createElement('div');
        ev.className = 'mock-cal-event new-event';
        ev.style.background = '#e91e63';
        ev.textContent = '14h - Dupont';
        ev.id = 'newPlanEvent';
        document.getElementById('cell3').appendChild(ev);

        hideCursor(cursor);
        await wait(2500);
    }
}

// ==================== BDC ANIMATION ====================
async function animateBdc() {
    const frame = document.getElementById('bdcFrame');
    const cursor = document.getElementById('bdcCursor');
    const listScreen = document.getElementById('bdcListScreen');
    const detailScreen = document.getElementById('bdcDetailScreen');

    while (true) {
        // Reset
        document.querySelectorAll('#bdcFrame tbody tr').forEach(r => r.classList.remove('row-highlight'));
        listScreen.className = 'mock-screen visible';
        detailScreen.className = 'mock-screen hidden';
        hideCursor(cursor);
        await wait(1200);

        showCursor(cursor);
        moveCursor(cursor, 300, 200);
        await wait(400);

        // Hover row 1
        const r1 = getRelativePos(document.getElementById('bdcRow1'), frame);
        moveCursor(cursor, r1.x, r1.y);
        await wait(500);
        document.getElementById('bdcRow1').classList.add('row-highlight');
        await wait(350);

        // Move to row 2
        const r2 = getRelativePos(document.getElementById('bdcRow2'), frame);
        moveCursor(cursor, r2.x, r2.y);
        await wait(500);
        document.getElementById('bdcRow1').classList.remove('row-highlight');
        document.getElementById('bdcRow2').classList.add('row-highlight');
        await wait(350);

        // Click visibility icon on row 2
        const visBtn = document.getElementById('bdcRow2').querySelector('.mock-icon-btn');
        const vp = getRelativePos(visBtn, frame);
        moveCursor(cursor, vp.x, vp.y);
        await wait(400);
        clickEffect(cursor);
        await wait(200);

        // Open BDC detail screen
        document.getElementById('bdcRow2').classList.remove('row-highlight');
        listScreen.className = 'mock-screen hidden';
        detailScreen.className = 'mock-screen visible';

        hideCursor(cursor);
        await wait(2500);

        // Go back to list
        showCursor(cursor);
        const backBtn = detailScreen.querySelector('.mock-presta-back');
        const backPos = getRelativePos(backBtn, frame);
        moveCursor(cursor, backPos.x, backPos.y);
        await wait(500);
        clickEffect(cursor);
        await wait(200);

        detailScreen.className = 'mock-screen hidden';
        listScreen.className = 'mock-screen visible';

        hideCursor(cursor);
        await wait(1500);
    }
}

// ==================== PRESTATION ANIMATION (TOUCH) ====================
function tapEffect(el) {
    el.style.transition = 'background 0.15s';
    const orig = el.style.background;
    el.style.background = 'rgba(63,81,181,0.12)';
    setTimeout(() => { el.style.background = orig; }, 300);
}

async function animatePrestation() {
    const listScreen = document.getElementById('prestaListScreen');
    const detailScreen = document.getElementById('prestaDetailScreen');
    const typingText = document.getElementById('typingText');
    const typingCursor = document.getElementById('typingCursor');
    const compteRendu = document.getElementById('compteRendu');
    const text = "Intervention realisee avec succes. Traitement applique dans les zones identifiees.";

    while (true) {
        // Reset
        listScreen.className = 'mock-screen visible';
        detailScreen.className = 'mock-screen hidden';
        typingText.textContent = '';
        typingCursor.style.display = 'none';
        compteRendu.classList.remove('focused');
        document.getElementById('cb1').classList.remove('checked');
        document.getElementById('cb2').classList.remove('checked');
        document.getElementById('cb3').classList.remove('checked');
        document.getElementById('sigPath').classList.remove('drawing');
        document.getElementById('sigPath').style.strokeDashoffset = '500';
        document.getElementById('sigPad').classList.remove('active');
        document.getElementById('terrainPrestaItem1').classList.remove('hover-effect');

        await wait(1500);

        // Tap on first prestation in list
        const item1 = document.getElementById('terrainPrestaItem1');
        tapEffect(item1);
        await wait(400);

        // Switch to detail screen
        listScreen.className = 'mock-screen hidden';
        detailScreen.className = 'mock-screen visible';
        await wait(600);

        // Tap on compte rendu field → start typing
        tapEffect(compteRendu);
        await wait(300);
        compteRendu.classList.add('focused');
        typingCursor.style.display = 'inline-block';

        for (let i = 0; i < text.length; i++) {
            typingText.textContent += text[i];
            await wait(18 + Math.random() * 18);
        }
        typingCursor.style.display = 'none';
        compteRendu.classList.remove('focused');
        await wait(400);

        // Tap checkboxes
        tapEffect(document.getElementById('cb1').parentElement);
        await wait(200);
        document.getElementById('cb1').classList.add('checked');
        await wait(400);

        tapEffect(document.getElementById('cb3').parentElement);
        await wait(200);
        document.getElementById('cb3').classList.add('checked');
        await wait(400);

        // Signature
        document.getElementById('sigPad').classList.add('active');
        document.getElementById('sigPath').classList.add('drawing');

        await wait(2800);
    }
}

// ==================== GEO ZONES ANIMATION ====================
async function animateGeo() {
    const frame = document.getElementById('geoFrame');
    const cursor = document.getElementById('geoCursor');
    const cityList = document.getElementById('geoCityList');
    const cityCount = document.getElementById('geoCityCount');
    const clickRing = document.getElementById('geoClickRing');
    const color = '#e91e63';

    const cities = [
        { id: 'geoCity1', labelId: 'geoCityLabel1', name: 'Aubervilliers' },
        { id: 'geoCity2', labelId: 'geoCityLabel2', name: 'Pantin' },
        { id: 'geoCity3', labelId: 'geoCityLabel3', name: 'Saint-Denis' },
        { id: 'geoCity4', labelId: 'geoCityLabel4', name: 'Le Pre-St-G.' },
        { id: 'geoCity5', labelId: 'geoCityLabel5', name: 'Bobigny' }
    ];

    while (true) {
        // Reset
        cities.forEach(c => {
            document.getElementById(c.id).style.fill = '#d0d4de';
            document.getElementById(c.id).classList.remove('colored');
            document.getElementById(c.labelId).classList.remove('colored');
        });
        cityList.innerHTML = '';
        cityCount.textContent = '0';
        hideCursor(cursor);
        await wait(1200);

        showCursor(cursor);
        moveCursor(cursor, 350, 200);
        await wait(400);

        // Click on each city one by one
        for (let i = 0; i < cities.length; i++) {
            const c = cities[i];
            const shape = document.getElementById(c.id);
            const label = document.getElementById(c.labelId);

            // Move cursor to city center
            const bbox = shape.getBBox();
            const svgEl = document.getElementById('geoMapSvg');
            const svgRect = svgEl.getBoundingClientRect();
            const frameRect = frame.getBoundingClientRect();
            const scaleX = svgRect.width / 500;
            const scaleY = svgRect.height / 380;
            const cx = svgRect.left - frameRect.left + (bbox.x + bbox.width / 2) * scaleX;
            const cy = svgRect.top - frameRect.top + (bbox.y + bbox.height / 2) * scaleY;

            moveCursor(cursor, cx, cy);
            await wait(500);
            clickEffect(cursor);
            await wait(150);

            // Color the city
            shape.style.fill = color;
            shape.classList.add('colored');
            label.classList.add('colored');

            // Click ring animation on SVG
            const svgCx = bbox.x + bbox.width / 2;
            const svgCy = bbox.y + bbox.height / 2;
            clickRing.setAttribute('cx', svgCx);
            clickRing.setAttribute('cy', svgCy);
            clickRing.setAttribute('stroke', color);
            clickRing.style.animation = 'none';
            clickRing.offsetHeight; // reflow
            clickRing.style.animation = 'clickRingPulse 0.5s ease-out forwards';

            // Add city to sidebar list
            const li = document.createElement('li');
            li.className = 'mock-geo-city';
            li.innerHTML = '<div class="mock-geo-city-dot" style="background:' + color + ';"></div> ' + c.name + ' <i class="material-icons" style="margin-left:auto;color:#bbb;">close</i>';
            cityList.appendChild(li);
            requestAnimationFrame(() => li.classList.add('visible'));

            cityCount.textContent = (i + 1).toString();
            await wait(400);
        }

        hideCursor(cursor);
        await wait(3000);
    }
}

// ==================== INIT ====================
const nav = document.getElementById('landingNav');
window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 50));

const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => { e.preventDefault(); const t = document.querySelector(a.getAttribute('href')); if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
});

// Start animations when visible
const animObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.dataset.started) {
            entry.target.dataset.started = 'true';
            const id = entry.target.id;
            if (id === 'planningFrame') animatePlanning();
            if (id === 'bdcFrame') animateBdc();
            if (id === 'prestaFrame') animatePrestation();
            if (id === 'geoFrame') animateGeo();
        }
    });
}, { threshold: 0.3 });

['planningFrame', 'bdcFrame', 'prestaFrame', 'geoFrame'].forEach(id => {
    const el = document.getElementById(id);
    if (el) animObserver.observe(el);
});
</script>

